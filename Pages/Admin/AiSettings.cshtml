@page "/admin/ai-settings"
@model chatbot.Pages.Admin.AiSettingsModel
@{
    ViewData["Title"] = "Cấu hình AI";
    ViewData["ActiveNav"] = "AiSettings";

    var connOk   = Model.WorkerReachable && Model.OllamaReachable;
    var connText = !Model.WorkerReachable ? "Worker offline" : (Model.OllamaReachable ? "Kết nối" : "Không kết nối");
}

@*
    Phase 1 = static shell with placeholder data. Provider switching, key
    saving, and "Kiểm tra" are mocked in JS below until later phases wire the
    real worker endpoints. Themed for BOTH light (default) and dark (dark:).
*@

<!-- Page Header -->
<div class="flex items-start justify-between mb-6">
    <div>
        <div class="flex items-center gap-2 mb-1">
            <i class="fa-solid fa-microchip text-gray-400"></i>
            <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-100">Cấu hình AI &amp; mô hình</h1>
        </div>
        <p class="text-sm text-gray-500 dark:text-gray-400">Quản lý nhà cung cấp, mô hình và khóa API cho trợ lý LD3.</p>
    </div>
</div>

<!-- Status Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-lg border border-gray-200 p-5 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center dark:bg-blue-900/30">
                <i class="fa-solid fa-server text-blue-500"></i>
            </div>
            <span class="text-sm text-gray-500 dark:text-gray-400">Đang dùng</span>
        </div>
        <p id="mProvider" class="text-lg font-bold text-gray-800 dark:text-gray-100">Ollama · Local</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-5 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 bg-violet-50 rounded-lg flex items-center justify-center dark:bg-violet-900/30">
                <i class="fa-solid fa-microchip text-violet-500"></i>
            </div>
            <span class="text-sm text-gray-500 dark:text-gray-400">Mô hình</span>
        </div>
        <p id="mModel" class="text-lg font-bold text-gray-800 font-mono dark:text-gray-100">@Model.ActiveModel</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-5 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 @(connOk ? "bg-green-50 dark:bg-green-900/30" : "bg-amber-50 dark:bg-amber-900/30") rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-circle-nodes @(connOk ? "text-green-500" : "text-amber-500")"></i>
            </div>
            <span class="text-sm text-gray-500 dark:text-gray-400">Ollama</span>
        </div>
        <p class="text-lg font-bold flex items-center gap-2 @(connOk ? "text-green-600 dark:text-green-400" : "text-amber-600 dark:text-amber-400")">
            <i class="fa-solid fa-circle text-[8px]"></i> @connText
        </p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-5 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 bg-amber-50 rounded-lg flex items-center justify-center dark:bg-amber-900/30">
                <i class="fa-solid fa-key text-amber-500"></i>
            </div>
            <span class="text-sm text-gray-500 dark:text-gray-400">Khóa API</span>
        </div>
        <p class="text-lg font-bold text-gray-800 dark:text-gray-100">1 / 3 đã cấu hình</p>
    </div>
</div>

<!-- Provider Routing -->
<div class="bg-white rounded-lg border border-gray-200 mb-6 dark:bg-gray-800 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-base font-bold text-gray-800 dark:text-gray-100">Nhà cung cấp &amp; định tuyến</h2>
        <p class="text-sm text-gray-500 mt-0.5 dark:text-gray-400">Chọn nguồn suy luận đang hoạt động. Mọi câu hỏi sẽ được định tuyến tới nhà cung cấp đang dùng.</p>
    </div>
    <div class="p-4 space-y-3">

        <!-- Ollama (active) -->
        <div data-provider-row data-ready="1" data-name="Ollama" data-kind="Local"
             class="flex items-center justify-between gap-3 flex-wrap p-3 rounded-lg border-2 border-blue-500 cursor-pointer">
            <div class="flex items-center gap-3 min-w-[200px]">
                <span data-radio class="w-3.5 h-3.5 rounded-full border-2 border-blue-500 bg-blue-500 shrink-0"></span>
                <div class="w-9 h-9 rounded-lg bg-blue-50 flex items-center justify-center dark:bg-blue-900/30">
                    <i class="fa-solid fa-server text-blue-500"></i>
                </div>
                <div>
                    <p class="text-sm font-medium text-gray-800 dark:text-gray-100">Ollama</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400">Cục bộ · không cần khóa</p>
                </div>
            </div>
            <div data-pgroup class="flex items-center gap-2 flex-wrap">
                <span data-active-badge class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300">Đang dùng</span>
                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium @(connOk ? "bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-300" : "bg-amber-50 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300")">
                    <i class="fa-solid @(connOk ? "fa-circle-check" : "fa-triangle-exclamation") text-[11px]"></i> @connText
                </span>
                <select class="h-9 w-40 px-2 border border-gray-300 rounded-lg text-sm bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500/30 dark:bg-gray-900 dark:border-gray-600 dark:text-gray-200">
                    @if (Model.InstalledModels.Count == 0)
                    {
                        <option>@Model.ActiveModel</option>
                    }
                    else
                    {
                        @foreach (var m in Model.InstalledModels)
                        {
                            <option selected="@(m == Model.ActiveModel)">@m</option>
                        }
                    }
                </select>
                <button type="button" data-test class="px-3 h-9 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50">
                    <i class="fa-solid fa-rotate text-xs"></i> Kiểm tra
                </button>
            </div>
        </div>

        <!-- OpenAI (configured, inactive) -->
        <div data-provider-row data-ready="1" data-name="OpenAI" data-kind="Cloud"
             class="flex items-center justify-between gap-3 flex-wrap p-3 rounded-lg border border-gray-200 cursor-pointer dark:border-gray-700">
            <div class="flex items-center gap-3 min-w-[200px]">
                <span data-radio class="w-3.5 h-3.5 rounded-full border-2 border-gray-300 shrink-0 dark:border-gray-600"></span>
                <div class="w-9 h-9 rounded-lg bg-gray-100 flex items-center justify-center dark:bg-gray-700">
                    <i class="fa-solid fa-brain text-gray-500 dark:text-gray-300"></i>
                </div>
                <div>
                    <p class="text-sm font-medium text-gray-800 dark:text-gray-100">OpenAI</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400">Đám mây · đã có khóa</p>
                </div>
            </div>
            <div data-pgroup class="flex items-center gap-2 flex-wrap">
                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-300">
                    <i class="fa-solid fa-key text-[11px]"></i> Khóa hợp lệ
                </span>
                <select class="h-9 w-40 px-2 border border-gray-300 rounded-lg text-sm bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500/30 dark:bg-gray-900 dark:border-gray-600 dark:text-gray-200">
                    <option>gpt-4o-mini</option><option>gpt-4o</option><option>o3-mini</option>
                </select>
                <button type="button" data-test class="px-3 h-9 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50">
                    <i class="fa-solid fa-rotate text-xs"></i> Kiểm tra
                </button>
            </div>
        </div>

        <!-- Anthropic (no key) -->
        <div data-provider-row data-ready="0" data-name="Anthropic" data-kind="Cloud"
             class="flex items-center justify-between gap-3 flex-wrap p-3 rounded-lg border border-gray-200 opacity-75 cursor-not-allowed dark:border-gray-700">
            <div class="flex items-center gap-3 min-w-[200px]">
                <span data-radio class="w-3.5 h-3.5 rounded-full border-2 border-gray-300 shrink-0 dark:border-gray-600"></span>
                <div class="w-9 h-9 rounded-lg bg-gray-100 flex items-center justify-center dark:bg-gray-700">
                    <i class="fa-solid fa-star text-gray-500 dark:text-gray-300"></i>
                </div>
                <div>
                    <p class="text-sm font-medium text-gray-800 dark:text-gray-100">Anthropic</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400">Đám mây · cần khóa API</p>
                </div>
            </div>
            <div data-pgroup class="flex items-center gap-2 flex-wrap">
                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-50 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300">
                    <i class="fa-solid fa-triangle-exclamation text-[11px]"></i> Chưa có khóa
                </span>
                <select disabled class="h-9 w-40 px-2 border border-gray-300 rounded-lg text-sm bg-gray-50 text-gray-400 dark:bg-gray-900 dark:border-gray-600 dark:text-gray-500">
                    <option>claude-haiku-4.5</option>
                </select>
                <button type="button" data-test disabled class="px-3 h-9 border border-gray-200 rounded-lg text-sm text-gray-400 cursor-not-allowed dark:border-gray-700 dark:text-gray-600">
                    <i class="fa-solid fa-rotate text-xs"></i> Kiểm tra
                </button>
            </div>
        </div>

        <!-- Google Gemini (no key) -->
        <div data-provider-row data-ready="0" data-name="Google Gemini" data-kind="Cloud"
             class="flex items-center justify-between gap-3 flex-wrap p-3 rounded-lg border border-gray-200 opacity-75 cursor-not-allowed dark:border-gray-700">
            <div class="flex items-center gap-3 min-w-[200px]">
                <span data-radio class="w-3.5 h-3.5 rounded-full border-2 border-gray-300 shrink-0 dark:border-gray-600"></span>
                <div class="w-9 h-9 rounded-lg bg-gray-100 flex items-center justify-center dark:bg-gray-700">
                    <i class="fa-brands fa-google text-gray-500 dark:text-gray-300"></i>
                </div>
                <div>
                    <p class="text-sm font-medium text-gray-800 dark:text-gray-100">Google Gemini</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400">Đám mây · cần khóa API</p>
                </div>
            </div>
            <div data-pgroup class="flex items-center gap-2 flex-wrap">
                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-50 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300">
                    <i class="fa-solid fa-triangle-exclamation text-[11px]"></i> Chưa có khóa
                </span>
                <select disabled class="h-9 w-40 px-2 border border-gray-300 rounded-lg text-sm bg-gray-50 text-gray-400 dark:bg-gray-900 dark:border-gray-600 dark:text-gray-500">
                    <option>gemini-2.0-flash</option>
                </select>
                <button type="button" data-test disabled class="px-3 h-9 border border-gray-200 rounded-lg text-sm text-gray-400 cursor-not-allowed dark:border-gray-700 dark:text-gray-600">
                    <i class="fa-solid fa-rotate text-xs"></i> Kiểm tra
                </button>
            </div>
        </div>
    </div>
</div>

<!-- API Keys -->
<div class="bg-white rounded-lg border border-gray-200 mb-6 dark:bg-gray-800 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-base font-bold text-gray-800 dark:text-gray-100">Khóa API (nhà cung cấp đám mây)</h2>
        <p class="text-sm text-gray-500 mt-0.5 dark:text-gray-400">Khóa được mã hóa khi lưu và không bao giờ hiển thị lại đầy đủ.</p>
    </div>
    <div class="p-6 space-y-4">
        @foreach (var k in new[] {
            new { Name = "OpenAI",    Value = "sk-proj-7Qd92ksLpZ", Placeholder = "sk-proj-...", Status = "Xác thực 5 phút trước", Ok = true },
            new { Name = "Anthropic", Value = "",                   Placeholder = "sk-ant-...",  Status = "Chưa cấu hình",       Ok = false },
            new { Name = "Gemini",    Value = "",                   Placeholder = "AIza...",     Status = "Chưa cấu hình",       Ok = false },
        })
        {
            <div class="flex items-center gap-3 flex-wrap">
                <span class="w-20 text-sm font-medium text-gray-700 dark:text-gray-200">@k.Name</span>
                <div class="relative flex-1 min-w-[220px]">
                    <input type="password" value="@k.Value" placeholder="@k.Placeholder"
                           class="w-full h-10 pl-3 pr-10 border border-gray-300 rounded-lg text-sm font-mono bg-white text-gray-700 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400 transition dark:bg-gray-900 dark:border-gray-600 dark:text-gray-100" />
                    <button type="button" data-eye class="absolute right-1 top-1 w-8 h-8 flex items-center justify-center text-gray-400 hover:text-gray-600 dark:hover:text-gray-200" aria-label="Hiện khóa">
                        <i class="fa-regular fa-eye text-sm"></i>
                    </button>
                </div>
                @if (k.Ok)
                {
                    <span class="text-xs text-green-600 dark:text-green-400 whitespace-nowrap"><i class="fa-solid fa-circle-check"></i> @k.Status</span>
                }
                else
                {
                    <span class="text-xs text-gray-400 whitespace-nowrap">@k.Status</span>
                }
                <button type="button" class="px-4 h-10 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50">Lưu</button>
            </div>
        }
    </div>
</div>

<!-- Advanced -->
<div class="bg-white rounded-lg border border-gray-200 dark:bg-gray-800 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-base font-bold text-gray-800 dark:text-gray-100">Cấu hình nâng cao</h2>
    </div>
    <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-5">
        <div>
            <div class="flex justify-between text-sm mb-2">
                <span class="text-gray-700 dark:text-gray-200">Nhiệt độ (temperature)</span>
                <span id="tOut" class="font-medium font-mono text-gray-800 dark:text-gray-100">0.1</span>
            </div>
            <input id="tRange" type="range" min="0" max="1" step="0.1" value="0.1" class="w-full accent-blue-600" />
            <p class="text-xs text-gray-400 mt-1">Thấp = bám sát tài liệu, ít sáng tạo.</p>
        </div>
        <div>
            <label class="block text-sm text-gray-700 mb-2 dark:text-gray-200">Số đoạn truy hồi (top-k)</label>
            <input type="number" value="12" class="w-full h-10 px-3 border border-gray-300 rounded-lg text-sm bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500/30 dark:bg-gray-900 dark:border-gray-600 dark:text-gray-100" />
        </div>
        <div>
            <label class="block text-sm text-gray-700 mb-2 dark:text-gray-200">Thời gian chờ (giây)</label>
            <input type="number" value="120" class="w-full h-10 px-3 border border-gray-300 rounded-lg text-sm bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500/30 dark:bg-gray-900 dark:border-gray-600 dark:text-gray-100" />
        </div>
        <div>
            <label class="block text-sm text-gray-700 mb-2 dark:text-gray-200">Ollama base URL</label>
            <input type="text" value="http://localhost:11434" class="w-full h-10 px-3 border border-gray-300 rounded-lg text-sm font-mono bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500/30 dark:bg-gray-900 dark:border-gray-600 dark:text-gray-100" />
        </div>
    </div>
</div>

<!-- Save bar -->
<div class="flex items-center justify-end gap-3 mt-6">
    <span class="mr-auto text-xs text-gray-400">
        <i class="fa-solid fa-clock-rotate-left"></i> Thay đổi cuối: hôm nay 09:42 bởi Quản trị viên LD3
    </span>
    <button type="button" class="px-5 h-10 border border-gray-300 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50 transition dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50">Hủy</button>
    <button type="button" class="px-5 h-10 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition shadow-sm">
        <i class="fa-solid fa-floppy-disk text-xs"></i> Lưu thay đổi
    </button>
</div>

@section Scripts {
<script>
    // Phase 1 mock interactions — pure UI, no backend yet.
    (function () {
        const tRange = document.getElementById('tRange');
        const tOut   = document.getElementById('tOut');
        tRange?.addEventListener('input', () => { tOut.textContent = parseFloat(tRange.value).toFixed(1); });

        // Show / hide API key
        document.querySelectorAll('[data-eye]').forEach(btn => {
            btn.addEventListener('click', () => {
                const input = btn.parentElement.querySelector('input');
                const icon  = btn.querySelector('i');
                if (input.type === 'password') { input.type = 'text';  icon.className = 'fa-regular fa-eye-slash text-sm'; }
                else                            { input.type = 'password'; icon.className = 'fa-regular fa-eye text-sm'; }
            });
        });

        // Select active provider
        const rows = document.querySelectorAll('[data-provider-row]');
        rows.forEach(row => {
            row.addEventListener('click', (e) => {
                if (e.target.closest('select') || e.target.closest('button')) return;
                if (row.dataset.ready !== '1') return;

                rows.forEach(r => {
                    r.classList.remove('border-2', 'border-blue-500');
                    r.classList.add('border', 'border-gray-200', 'dark:border-gray-700');
                    const dot = r.querySelector('[data-radio]');
                    dot.classList.remove('border-blue-500', 'bg-blue-500');
                    dot.classList.add('border-gray-300', 'dark:border-gray-600');
                    const badge = r.querySelector('[data-active-badge]');
                    if (badge) badge.remove();
                });

                row.classList.remove('border', 'border-gray-200', 'dark:border-gray-700');
                row.classList.add('border-2', 'border-blue-500');
                const dot = row.querySelector('[data-radio]');
                dot.classList.remove('border-gray-300', 'dark:border-gray-600');
                dot.classList.add('border-blue-500', 'bg-blue-500');

                const badge = document.createElement('span');
                badge.setAttribute('data-active-badge', '');
                badge.className = 'inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300';
                badge.textContent = 'Đang dùng';
                const group = row.querySelector('[data-pgroup]');
                group.insertBefore(badge, group.firstChild);

                document.getElementById('mProvider').textContent = `${row.dataset.name} · ${row.dataset.kind}`;
                const sel = row.querySelector('select');
                if (sel) document.getElementById('mModel').textContent = sel.value;
            });
        });

        // Mock connectivity test
        document.querySelectorAll('[data-test]').forEach(btn => {
            if (btn.disabled) return;
            const original = btn.innerHTML;
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                btn.disabled = true;
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin text-xs"></i> Đang kiểm tra…';
                setTimeout(() => {
                    btn.innerHTML = '<i class="fa-solid fa-circle-check text-xs text-green-500"></i> Hoạt động';
                    setTimeout(() => { btn.innerHTML = original; btn.disabled = false; }, 1600);
                }, 800);
            });
        });
    })();
</script>
}
