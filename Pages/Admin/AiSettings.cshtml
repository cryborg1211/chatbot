@page "/admin/ai-settings"
@model chatbot.Pages.Admin.AiSettingsModel
@{
    ViewData["Title"] = "Cấu hình AI";
    ViewData["ActiveNav"] = "AiSettings";
}

@*
    Initial render is shell-only (no worker call). The JS below fetches live
    status from ?handler=Status and fills the DOM, so a slow/offline worker
    never blocks the page. Key save + connectivity test + provider switch are
    real AJAX calls. Themed for light (default) and dark.
*@

<!-- Page Header -->
<div class="flex items-start justify-between mb-6">
    <div>
        <div class="flex items-center gap-2 mb-1">
            <i class="fa-solid fa-microchip text-gray-400"></i>
            <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-100">Cấu hình AI &amp; mô hình</h1>
        </div>
        <p class="text-sm text-gray-500 dark:text-gray-400">Quản lý nhà cung cấp, mô hình và khóa API cho trợ lý LD3.</p>
    </div>
</div>

@if (Model.Saved)
{
    <div class="mb-6 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700 flex items-center gap-2 dark:bg-green-900/20 dark:border-green-800 dark:text-green-300">
        <i class="fa-solid fa-circle-check"></i> Đã lưu cấu hình AI.
    </div>
}

<!-- Status Cards (filled by JS) -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-lg border border-gray-200 p-5 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center dark:bg-blue-900/30"><i class="fa-solid fa-server text-blue-500"></i></div>
            <span class="text-sm text-gray-500 dark:text-gray-400">Đang dùng</span>
        </div>
        <p id="mProvider" class="text-lg font-bold text-gray-800 dark:text-gray-100">…</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-5 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 bg-violet-50 rounded-lg flex items-center justify-center dark:bg-violet-900/30"><i class="fa-solid fa-microchip text-violet-500"></i></div>
            <span class="text-sm text-gray-500 dark:text-gray-400">Mô hình</span>
        </div>
        <p id="mModel" class="text-lg font-bold text-gray-800 font-mono dark:text-gray-100">@(Model.ActiveModel ?? "…")</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-5 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 bg-gray-100 rounded-lg flex items-center justify-center dark:bg-gray-700"><i class="fa-solid fa-circle-nodes text-gray-400"></i></div>
            <span class="text-sm text-gray-500 dark:text-gray-400">Ollama</span>
        </div>
        <p id="ollamaStatus" class="text-lg font-bold text-gray-400 flex items-center gap-2">Đang tải…</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-5 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 bg-amber-50 rounded-lg flex items-center justify-center dark:bg-amber-900/30"><i class="fa-solid fa-key text-amber-500"></i></div>
            <span class="text-sm text-gray-500 dark:text-gray-400">Khóa API</span>
        </div>
        <p id="keyCount" class="text-lg font-bold text-gray-800 dark:text-gray-100">…</p>
    </div>
</div>

<form method="post">
<input type="hidden" name="SelectedProvider" id="selProvider" value="@Model.ActiveProvider" />
<input type="hidden" name="SelectedModel" id="selModel" value="@Model.ActiveModel" />

<!-- Provider Routing -->
<div class="bg-white rounded-lg border border-gray-200 mb-6 dark:bg-gray-800 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-base font-bold text-gray-800 dark:text-gray-100">Nhà cung cấp &amp; định tuyến</h2>
        <p class="text-sm text-gray-500 mt-0.5 dark:text-gray-400">Chọn nguồn suy luận đang hoạt động, rồi bấm "Lưu thay đổi". Nhà cung cấp đám mây cần khóa API.</p>
    </div>
    <div class="p-4 space-y-3">

        <!-- Ollama -->
        <div data-provider-row data-provider="ollama" data-cloud="0" data-ready="1"
             class="flex items-center justify-between gap-3 flex-wrap p-3 rounded-lg border border-gray-200 cursor-pointer dark:border-gray-700">
            <div class="flex items-center gap-3 min-w-[200px]">
                <span data-radio class="w-3.5 h-3.5 rounded-full border-2 border-gray-300 shrink-0 dark:border-gray-600"></span>
                <div class="w-9 h-9 rounded-lg bg-blue-50 flex items-center justify-center dark:bg-blue-900/30"><i class="fa-solid fa-server text-blue-500"></i></div>
                <div>
                    <p class="text-sm font-medium text-gray-800 dark:text-gray-100">Ollama</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400">Cục bộ · không cần khóa</p>
                </div>
            </div>
            <div class="flex items-center gap-2 flex-wrap">
                <span data-active-badge class="hidden inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300">Đang dùng</span>
                <span data-status class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-500 dark:bg-gray-700 dark:text-gray-300">…</span>
                <select data-model-select class="h-9 w-44 px-2 border border-gray-300 rounded-lg text-sm bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500/30 dark:bg-gray-900 dark:border-gray-600 dark:text-gray-200">
                    <option>@(Model.ActiveModel ?? "…")</option>
                </select>
                <button type="button" data-sync data-provider="ollama" class="px-3 h-9 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50"><i class="fa-solid fa-arrows-rotate text-xs"></i> Đồng bộ &amp; kiểm tra</button>
            </div>
        </div>

        @foreach (var prov in new[] {
            new { Id = "openai",    Name = "OpenAI",        Icon = "fa-solid fa-brain",    Brand = false },
            new { Id = "anthropic", Name = "Anthropic",     Icon = "fa-solid fa-star",     Brand = false },
            new { Id = "gemini",    Name = "Google Gemini", Icon = "fa-brands fa-google",  Brand = false },
        })
        {
            <div data-provider-row data-provider="@prov.Id" data-cloud="1" data-ready="0"
                 class="flex items-center justify-between gap-3 flex-wrap p-3 rounded-lg border border-gray-200 opacity-75 cursor-not-allowed dark:border-gray-700">
                <div class="flex items-center gap-3 min-w-[200px]">
                    <span data-radio class="w-3.5 h-3.5 rounded-full border-2 border-gray-300 shrink-0 dark:border-gray-600"></span>
                    <div class="w-9 h-9 rounded-lg bg-gray-100 flex items-center justify-center dark:bg-gray-700"><i class="@prov.Icon text-gray-500 dark:text-gray-300"></i></div>
                    <div>
                        <p class="text-sm font-medium text-gray-800 dark:text-gray-100">@prov.Name</p>
                        <p class="text-xs text-gray-500 dark:text-gray-400">Đám mây · cần khóa API</p>
                    </div>
                </div>
                <div class="flex items-center gap-2 flex-wrap">
                    <span data-active-badge class="hidden inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300">Đang dùng</span>
                    <span data-status class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-50 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300"><i class="fa-solid fa-triangle-exclamation text-[11px]"></i> Chưa có khóa</span>
                    <select data-model-select disabled class="h-9 w-44 px-2 border border-gray-300 rounded-lg text-sm bg-gray-50 text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500/30 dark:bg-gray-900 dark:border-gray-600 dark:text-gray-200">
                        <option>— bấm 🔄 —</option>
                    </select>
                    <button type="button" data-sync data-provider="@prov.Id" class="px-3 h-9 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50"><i class="fa-solid fa-arrows-rotate text-xs"></i> Đồng bộ &amp; kiểm tra</button>
                </div>
            </div>
        }
    </div>
</div>

<!-- API Keys -->
<div class="bg-white rounded-lg border border-gray-200 mb-6 dark:bg-gray-800 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-base font-bold text-gray-800 dark:text-gray-100">Khóa API (nhà cung cấp đám mây)</h2>
        <p class="text-sm text-gray-500 mt-0.5 dark:text-gray-400">Khóa được mã hóa khi lưu và không bao giờ hiển thị lại.</p>
    </div>
    <div class="p-6 space-y-4">
        @foreach (var k in new[] {
            new { Id = "openai",    Name = "OpenAI",    Placeholder = "sk-proj-..." },
            new { Id = "anthropic", Name = "Anthropic", Placeholder = "sk-ant-..." },
            new { Id = "gemini",    Name = "Gemini",    Placeholder = "AIza..." },
        })
        {
            <div class="flex items-center gap-3 flex-wrap">
                <span class="w-20 text-sm font-medium text-gray-700 dark:text-gray-200">@k.Name</span>
                <div class="relative flex-1 min-w-[220px]">
                    <input type="password" data-key-input="@k.Id" placeholder="@k.Placeholder"
                           class="w-full h-10 pl-3 pr-10 border border-gray-300 rounded-lg text-sm font-mono bg-white text-gray-700 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400 transition dark:bg-gray-900 dark:border-gray-600 dark:text-gray-100" />
                    <button type="button" data-eye class="absolute right-1 top-1 w-8 h-8 flex items-center justify-center text-gray-400 hover:text-gray-600 dark:hover:text-gray-200" aria-label="Hiện khóa"><i class="fa-regular fa-eye text-sm"></i></button>
                </div>
                <span id="keyStatus-@k.Id" class="text-xs text-gray-400 whitespace-nowrap">…</span>
                <button type="button" data-save-key="@k.Id" class="px-4 h-10 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50">Lưu</button>
            </div>
        }
    </div>
</div>

<!-- Advanced (deferred) -->
<div class="bg-white rounded-lg border border-gray-200 dark:bg-gray-800 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center gap-2">
        <h2 class="text-base font-bold text-gray-800 dark:text-gray-100">Cấu hình nâng cao</h2>
        <span class="px-2 py-0.5 rounded-full text-[11px] font-medium bg-gray-100 text-gray-500 dark:bg-gray-700 dark:text-gray-300">Sắp có</span>
    </div>
    <fieldset disabled class="p-6 grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-5 border-0 opacity-60">
        <div>
            <div class="flex justify-between text-sm mb-2">
                <span class="text-gray-700 dark:text-gray-200">Nhiệt độ (temperature)</span>
                <span id="tOut" class="font-medium font-mono text-gray-800 dark:text-gray-100">0.1</span>
            </div>
            <input id="tRange" type="range" min="0" max="1" step="0.1" value="0.1" class="w-full accent-blue-600" />
        </div>
        <div>
            <label class="block text-sm text-gray-700 mb-2 dark:text-gray-200">Số đoạn truy hồi (top-k)</label>
            <input type="number" value="12" class="w-full h-10 px-3 border border-gray-300 rounded-lg text-sm bg-white text-gray-700 dark:bg-gray-900 dark:border-gray-600 dark:text-gray-100" />
        </div>
    </fieldset>
</div>

<!-- Save bar -->
<div class="flex items-center justify-end gap-3 mt-6">
    <span class="mr-auto text-xs text-gray-400">
        <i class="fa-solid fa-clock-rotate-left"></i>
        @if (Model.UpdatedBy is not null)
        {
            <text>Thay đổi cuối: @Model.UpdatedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") bởi @Model.UpdatedBy</text>
        }
        else
        {
            <text>Chưa có thay đổi nào được lưu.</text>
        }
    </span>
    <a href="/admin/ai-settings" class="px-5 h-10 flex items-center border border-gray-300 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50 transition dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50">Hủy</a>
    <button type="submit" class="px-5 h-10 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition shadow-sm"><i class="fa-solid fa-floppy-disk text-xs"></i> Lưu thay đổi</button>
</div>
</form>

@section Scripts {
<script>
    (function () {
        const tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
        const token = tokenEl ? tokenEl.value : '';
        const selProvider = document.getElementById('selProvider');
        const selModel = document.getElementById('selModel');
        const rows = Array.from(document.querySelectorAll('[data-provider-row]'));
        const label = { ollama: 'Ollama · Local', openai: 'OpenAI · Cloud', anthropic: 'Anthropic · Cloud', gemini: 'Google Gemini · Cloud' };

        function setActive(provider) {
            rows.forEach(r => {
                const on = r.dataset.provider === provider;
                r.classList.toggle('border-2', on);
                r.classList.toggle('border-blue-500', on);
                r.classList.toggle('border', !on);
                r.classList.toggle('border-gray-200', !on);
                r.classList.toggle('dark:border-gray-700', !on);
                const dot = r.querySelector('[data-radio]');
                dot.classList.toggle('border-blue-500', on);
                dot.classList.toggle('bg-blue-500', on);
                dot.classList.toggle('border-gray-300', !on);
                dot.classList.toggle('dark:border-gray-600', !on);
                const b = r.querySelector('[data-active-badge]');
                if (b) b.classList.toggle('hidden', !on);
            });
            selProvider.value = provider;
            const row = rows.find(r => r.dataset.provider === provider);
            const sel = row && row.querySelector('[data-model-select]');
            selModel.value = sel ? sel.value : '';
            document.getElementById('mProvider').textContent = label[provider] || provider;
            document.getElementById('mModel').textContent = selModel.value || '—';
        }

        rows.forEach(r => {
            r.addEventListener('click', e => {
                if (e.target.closest('select') || e.target.closest('button')) return;
                if (r.dataset.ready !== '1') return;
                setActive(r.dataset.provider);
            });
            const sel = r.querySelector('[data-model-select]');
            if (sel) sel.addEventListener('change', () => {
                if (selProvider.value === r.dataset.provider) {
                    selModel.value = sel.value;
                    document.getElementById('mModel').textContent = sel.value;
                }
            });
        });

        function keyBadge(row, has) {
            const b = row.querySelector('[data-status]');
            if (!b) return;
            b.innerHTML = has
                ? '<i class="fa-solid fa-key text-[11px]"></i> Khóa hợp lệ'
                : '<i class="fa-solid fa-triangle-exclamation text-[11px]"></i> Chưa có khóa';
            b.className = 'inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium ' +
                (has ? 'bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-300'
                     : 'bg-amber-50 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300');
        }

        async function loadStatus() {
            try {
                const res = await fetch('?handler=Status', { headers: { 'Accept': 'application/json' } });
                if (!res.ok) return;
                const d = await res.json();

                const oc = document.getElementById('ollamaStatus');
                if (!d.workerReachable) { oc.textContent = 'Worker offline'; oc.className = 'text-lg font-bold text-amber-600 dark:text-amber-400'; }
                else if (d.ollamaReachable) { oc.innerHTML = '<i class="fa-solid fa-circle text-[8px]"></i> Kết nối'; oc.className = 'text-lg font-bold text-green-600 dark:text-green-400 flex items-center gap-2'; }
                else { oc.textContent = 'Không kết nối'; oc.className = 'text-lg font-bold text-amber-600 dark:text-amber-400'; }

                const ollamaRow = rows.find(r => r.dataset.provider === 'ollama');
                const oStatus = ollamaRow.querySelector('[data-status]');
                if (d.ollamaReachable) { oStatus.innerHTML = '<i class="fa-solid fa-circle-check text-[11px]"></i> Kết nối'; oStatus.className = 'inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-300'; }
                else { oStatus.innerHTML = '<i class="fa-solid fa-triangle-exclamation text-[11px]"></i> Không kết nối'; oStatus.className = 'inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-50 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300'; }

                const om = ollamaRow.querySelector('[data-model-select]');
                om.innerHTML = '';
                (d.installedModels || []).forEach(m => {
                    const o = document.createElement('option');
                    o.textContent = m;
                    if (m === d.activeModel) o.selected = true;
                    om.appendChild(o);
                });
                if (!om.children.length) { const o = document.createElement('option'); o.textContent = d.activeModel || '—'; om.appendChild(o); }

                const configured = new Set(d.configured || []);
                document.getElementById('keyCount').textContent = configured.size + ' / 3 đã cấu hình';
                rows.filter(r => r.dataset.cloud === '1').forEach(r => {
                    const p = r.dataset.provider;
                    const has = configured.has(p);
                    r.dataset.ready = has ? '1' : '0';
                    r.classList.toggle('opacity-75', !has);
                    r.classList.toggle('cursor-not-allowed', !has);
                    r.classList.toggle('cursor-pointer', has);
                    const sel = r.querySelector('[data-model-select]'); if (sel) sel.disabled = !has;
                    const tb = r.querySelector('[data-test]');
                    if (tb) { tb.disabled = !has; tb.classList.toggle('cursor-not-allowed', !has); tb.classList.toggle('text-gray-400', !has); }
                    keyBadge(r, has);
                    const ks = document.getElementById('keyStatus-' + p);
                    if (ks) { ks.textContent = has ? 'Đã cấu hình' : 'Chưa cấu hình'; ks.className = has ? 'text-xs text-green-600 dark:text-green-400 whitespace-nowrap' : 'text-xs text-gray-400 whitespace-nowrap'; }
                });

                // Show the saved model in the active provider's dropdown, even for
                // a cloud provider whose list hasn't been synced this session.
                const activeRow = rows.find(r => r.dataset.provider === (d.activeProvider || 'ollama'));
                if (activeRow && d.activeModel) {
                    const asel = activeRow.querySelector('[data-model-select]');
                    let opt = Array.from(asel.options).find(o => o.textContent === d.activeModel);
                    if (!opt) { opt = document.createElement('option'); opt.textContent = d.activeModel; asel.insertBefore(opt, asel.firstChild); }
                    opt.selected = true;
                }

                setActive(d.activeProvider || 'ollama');
            } catch (e) { /* status is non-critical */ }
        }

        document.querySelectorAll('[data-eye]').forEach(btn => {
            btn.addEventListener('click', () => {
                const i = btn.parentElement.querySelector('input');
                const ic = btn.querySelector('i');
                if (i.type === 'password') { i.type = 'text'; ic.className = 'fa-regular fa-eye-slash text-sm'; }
                else { i.type = 'password'; ic.className = 'fa-regular fa-eye text-sm'; }
            });
        });

        document.querySelectorAll('[data-save-key]').forEach(btn => {
            btn.addEventListener('click', async () => {
                const p = btn.dataset.saveKey;
                const inp = document.querySelector('[data-key-input="' + p + '"]');
                const key = inp.value.trim();
                if (!key) { inp.focus(); return; }
                const orig = btn.textContent;
                btn.disabled = true; btn.textContent = 'Đang lưu…';
                try {
                    const fd = new FormData(); fd.append('provider', p); fd.append('key', key);
                    const res = await fetch('?handler=SaveKey', { method: 'POST', headers: { 'RequestVerificationToken': token }, body: fd });
                    const d = await res.json();
                    if (d.ok) { inp.value = ''; inp.placeholder = '••••••• đã lưu'; await loadStatus(); }
                    else alert(d.error || 'Lưu thất bại.');
                } catch (e) { alert('Lỗi kết nối.'); }
                finally { btn.disabled = false; btn.textContent = orig; }
            });
        });

        // Combined sync + auth check: /llm/models does an authenticated GET, so a
        // 200 both validates the key and returns the live text-only model list.
        document.querySelectorAll('[data-sync]').forEach(btn => {
            const orig = btn.innerHTML;
            btn.addEventListener('click', async e => {
                e.stopPropagation();
                const p = btn.dataset.provider;
                const row = rows.find(r => r.dataset.provider === p);
                const sel = row.querySelector('[data-model-select]');
                btn.disabled = true;
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin text-xs"></i> Đang đồng bộ…';
                try {
                    const fd = new FormData(); fd.append('provider', p);
                    const res = await fetch('?handler=Models', { method: 'POST', headers: { 'RequestVerificationToken': token }, body: fd });
                    const d = await res.json();
                    if (d.ok) {
                        const cur = sel.value;
                        sel.innerHTML = '';
                        (d.models || []).forEach(m => { const o = document.createElement('option'); o.textContent = m; if (m === cur) o.selected = true; sel.appendChild(o); });
                        if (!sel.children.length) { const o = document.createElement('option'); o.textContent = '(không có mô hình text)'; sel.appendChild(o); }
                        if (selProvider.value === p) { selModel.value = sel.value; document.getElementById('mModel').textContent = sel.value; }
                        btn.innerHTML = '<i class="fa-solid fa-circle-check text-xs text-green-500"></i> ' + ((d.models || []).length) + ' mô hình';
                        btn.title = '';
                    } else {
                        btn.innerHTML = '<i class="fa-solid fa-circle-xmark text-xs text-red-500"></i> Lỗi';
                        btn.title = d.error || '';
                        alert('Thất bại: ' + (d.error || 'lỗi không rõ'));
                    }
                } catch (e) { btn.innerHTML = '<i class="fa-solid fa-circle-xmark text-xs text-red-500"></i> Lỗi'; alert('Lỗi kết nối.'); }
                finally { setTimeout(() => { btn.innerHTML = orig; btn.disabled = false; }, 2500); }
            });
        });

        loadStatus();
    })();
</script>
}
