@page
@model chatbot.Pages.Admin.LogsModel
@using chatbot.Models
@{
    ViewData["Title"] = "Nhật ký hệ thống";
    ViewData["ActiveNav"] = "Logs";

    (string Bg, string Text, string Icon, string Label) ActionChip(string action) => action switch
    {
        "auth.login"          => ("bg-blue-50",  "text-blue-700",  "fa-solid fa-right-to-bracket", "Đăng nhập"),
        "auth.logout"         => ("bg-gray-100", "text-gray-600",  "fa-solid fa-right-from-bracket","Đăng xuất"),
        "auth.login_failed"   => ("bg-red-50",   "text-red-600",   "fa-solid fa-circle-xmark",     "Đăng nhập thất bại"),
        "auth.register"       => ("bg-violet-50","text-violet-700","fa-solid fa-user-plus",        "Đăng ký"),
        "user.approve"        => ("bg-green-50", "text-green-700", "fa-solid fa-circle-check",     "Phê duyệt"),
        "user.reject"         => ("bg-red-50",   "text-red-600",   "fa-solid fa-ban",              "Từ chối"),
        "doc.upload"          => ("bg-gray-100", "text-gray-700",  "fa-solid fa-arrow-up-from-bracket","Tải lên"),
        "doc.ingest_success"  => ("bg-green-50", "text-green-700", "fa-solid fa-circle-check",     "Vector hoá xong"),
        "doc.ingest_failed"   => ("bg-red-50",   "text-red-600",   "fa-solid fa-circle-exclamation","Vector hoá lỗi"),
        "doc.delete"          => ("bg-red-50",   "text-red-600",   "fa-regular fa-trash-can",      "Xoá tài liệu"),
        "chat.start"          => ("bg-blue-50",  "text-blue-700",  "fa-regular fa-comment-dots",   "Tạo cuộc trò chuyện"),
        "chat.message"        => ("bg-blue-50",  "text-blue-700",  "fa-regular fa-comment",        "Trò chuyện"),
        "chat.error"          => ("bg-red-50",   "text-red-600",   "fa-solid fa-circle-exclamation","Lỗi chat"),
        "feedback.submit"     => ("bg-amber-50", "text-amber-700", "fa-solid fa-thumbs-up",        "Gửi phản hồi"),
        "feedback.update"     => ("bg-amber-50", "text-amber-700", "fa-solid fa-thumbs-up",        "Sửa phản hồi"),
        "system.startup"      => ("bg-emerald-50","text-emerald-700","fa-solid fa-power-off",      "Khởi động hệ thống"),
        "system.shutdown"     => ("bg-gray-100", "text-gray-700",  "fa-solid fa-power-off",        "Tắt hệ thống"),
        _                      => ("bg-gray-100","text-gray-600",  "fa-solid fa-circle",           action)
    };
}

<!-- Page Header -->
<div class="flex items-start justify-between mb-6">
    <div>
        <div class="flex items-center gap-2 mb-1">
            <i class="fa-solid fa-terminal text-gray-400"></i>
            <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-100">Nhật ký hệ thống</h1>
        </div>
        <p class="text-sm text-gray-500 dark:text-gray-400">Theo dõi và giám sát mọi hoạt động trên nền tảng. Hiển thị @Model.Total24h sự kiện trong 24 giờ qua.</p>
    </div>
</div>

<!-- Filter Bar -->
<form method="get" class="flex items-center gap-3 mb-6 flex-wrap bg-white border border-gray-200 rounded-lg p-3 dark:bg-gray-800 dark:border-gray-700">
    <div class="relative flex-1 min-w-[200px]">
        <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
        <input type="text" name="Action" value="@Model.Action" placeholder="Lọc theo mã hành động (ví dụ: doc.upload)"
               class="w-full h-10 pl-10 pr-4 bg-white border border-gray-300 rounded-lg text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400 transition dark:bg-gray-900 dark:border-gray-600 dark:text-gray-100" />
    </div>
    <select name="Category" class="h-10 px-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400 dark:bg-gray-900 dark:border-gray-600 dark:text-gray-200">
        <option value="">Tất cả danh mục</option>
        @foreach (var c in Model.KnownCategories)
        {
            <option value="@c" selected="@(Model.Category == c)">@c</option>
        }
    </select>
    <input type="datetime-local" name="FromDate" value="@(Model.FromDate?.ToString("yyyy-MM-ddTHH:mm"))"
           class="h-10 px-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white dark:bg-gray-900 dark:border-gray-600 dark:text-gray-200" />
    <input type="datetime-local" name="ToDate" value="@(Model.ToDate?.ToString("yyyy-MM-ddTHH:mm"))"
           class="h-10 px-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white dark:bg-gray-900 dark:border-gray-600 dark:text-gray-200" />
    <button type="submit" class="px-5 h-10 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition">Lọc</button>
    <a href="?" class="px-3 h-10 flex items-center text-sm text-gray-500 hover:text-gray-800 transition dark:text-gray-400 dark:hover:text-gray-100">Xoá lọc</a>
</form>

<!-- Activity Log Table -->
<div class="bg-white rounded-lg border border-gray-200 dark:bg-gray-800 dark:border-gray-700">
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <div>
            <h2 class="text-base font-bold text-gray-800 dark:text-gray-100">Hoạt động hệ thống</h2>
            <p class="text-sm text-gray-500 mt-0.5 dark:text-gray-400">Trang @Model.PageNumber / @Model.TotalPages · @Model.TotalCount sự kiện khớp bộ lọc.</p>
        </div>
        <span class="text-xs text-blue-600 bg-blue-50 px-3 py-1.5 rounded-full font-medium border border-blue-100 dark:bg-blue-900/40 dark:text-blue-300 dark:border-blue-800">
            @Model.Items.Count bản ghi
        </span>
    </div>

    <table class="w-full">
        <thead>
            <tr class="border-b border-gray-100 bg-gray-50/50 dark:border-gray-700 dark:bg-gray-900/30">
                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3 w-44">Thời gian</th>
                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3 w-52">Người dùng</th>
                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3 w-44">Hành động</th>
                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Tài nguyên</th>
                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3 w-36">Địa chỉ IP</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="5" class="px-6 py-12 text-center text-sm text-gray-400">Không có sự kiện nào.</td></tr>
            }
            @foreach (var l in Model.Items)
            {
                var chip = ActionChip(l.Action);
                var rowBg = l.Severity >= LogSeverity.Error ? "bg-red-50/30" : "";
                <tr class="hover:bg-gray-50/50 transition dark:hover:bg-gray-700/30 @rowBg" title="@l.Action">
                    <td class="px-6 py-4 text-sm text-gray-600 font-mono dark:text-gray-300">@l.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td class="px-6 py-4">
                        @if (l.UserId is null)
                        {
                            <span class="text-xs text-gray-400 italic">hệ thống / ẩn danh</span>
                        }
                        else
                        {
                            <p class="text-sm font-semibold text-gray-800 truncate max-w-[12rem] dark:text-gray-100" title="@l.UserId">@(l.UserFullName ?? l.UserId)</p>
                            <p class="text-xs text-gray-400">@l.DepartmentId</p>
                        }
                    </td>
                    <td class="px-6 py-4">
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 @chip.Bg @chip.Text rounded-full text-xs font-medium">
                            <i class="@chip.Icon text-[10px]"></i> @chip.Label
                        </span>
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-600 truncate max-w-md dark:text-gray-300" title="@l.ResourceId">
                        @if (l.ResourceType is not null)
                        {
                            <span class="text-xs text-gray-400">@l.ResourceType:</span>
                        }
                        @if (l.ResourceName is not null)
                        {
                            <span class="inline-flex items-center gap-1">
                                <i class="fa-regular fa-file-lines text-gray-400 text-xs"></i>
                                @l.ResourceName
                            </span>
                        }
                        else
                        {
                            @l.ResourceId
                        }
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-500 font-mono dark:text-gray-400">@l.IpAddress</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="flex items-center justify-between px-6 py-4 border-t border-gray-200 dark:border-gray-700">
        <p class="text-sm text-gray-500">Tổng @Model.TotalCount sự kiện · trang @Model.PageNumber / @Model.TotalPages</p>
        @{
            var prev = Math.Max(1, Model.PageNumber - 1);
            var next = Math.Min(Model.TotalPages, Model.PageNumber + 1);
            string Qs(int p) => $"?Action={Model.Action}&Category={Model.Category}&FromDate={Model.FromDate?.ToString("yyyy-MM-ddTHH:mm")}&ToDate={Model.ToDate?.ToString("yyyy-MM-ddTHH:mm")}&PageNumber={p}";
        }
        <div class="flex items-center gap-1">
            <a href="@Qs(prev)" class="px-3 py-1.5 text-sm text-gray-600 rounded-lg border border-gray-300 hover:bg-gray-50 transition dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-700/50">Trước</a>
            <span class="w-8 h-8 flex items-center justify-center rounded-lg text-sm bg-blue-600 text-white font-medium">@Model.PageNumber</span>
            <a href="@Qs(next)" class="px-3 py-1.5 text-sm text-gray-600 rounded-lg border border-gray-300 hover:bg-gray-50 transition dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-700/50">Sau</a>
        </div>
    </div>
</div>
