@page
@model chatbot.Pages.Admin.DocumentsModel
@using chatbot.Models
@{
    Layout = null;

    // ---- Local rendering helpers (kept inline — they're page-specific) ----

    (string Wrap, string Icon, string Label) StatusChip(DocumentStatus s) => s switch
    {
        DocumentStatus.Ready      => ("bg-green-50 text-green-700",  "fa-solid fa-circle-check",         "Đã sẵn sàng"),
        DocumentStatus.Processing => ("bg-yellow-50 text-yellow-700","fa-solid fa-spinner fa-spin",      "Đang vector hóa"),
        DocumentStatus.Pending    => ("bg-gray-100 text-gray-600",   "fa-regular fa-clock",              "Chờ xử lý"),
        DocumentStatus.Failed     => ("bg-red-100 text-red-600",     "fa-solid fa-circle-exclamation",   "Lỗi xử lý"),
        _                          => ("bg-gray-100 text-gray-600",  "fa-solid fa-circle",               s.ToString())
    };

    (string BgClass, string TextClass, string IconClass) FileIcon(string mime) => mime switch
    {
        "application/pdf"  => ("bg-red-50",   "text-red-500",   "fa-regular fa-file-pdf"),
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
                           => ("bg-blue-50",  "text-blue-500",  "fa-regular fa-file-word"),
        "text/plain"       => ("bg-gray-50",  "text-gray-500",  "fa-regular fa-file-lines"),
        _                  => ("bg-gray-50",  "text-gray-500",  "fa-regular fa-file")
    };

    string FormatSize(long bytes) => bytes switch
    {
        < 1024              => $"{bytes} B",
        < 1024L * 1024      => $"{bytes / 1024.0:F1} KB",
        _                   => $"{bytes / (1024.0 * 1024.0):F1} MB"
    };
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản lý tài liệu tri thức - LD3 AI Chatbot</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body class="bg-gray-50 text-gray-800 antialiased min-h-screen flex flex-col">

    <!-- ==================== TOP BAR ==================== -->
    <header class="h-14 bg-white border-b border-gray-200 flex items-center justify-between px-5 shrink-0">
        <div class="flex items-center gap-3">
            <a href="/Chat" class="w-8 h-8 flex items-center justify-center text-gray-500 hover:bg-gray-100 rounded-lg transition">
                <i class="fa-solid fa-arrow-left text-sm"></i>
            </a>
            <a href="/" class="flex items-center gap-2.5">
                <div class="w-8 h-8 rounded-full bg-blue-50 flex items-center justify-center">
                    <i class="fa-solid fa-heart-pulse text-blue-500"></i>
                </div>
                <span class="text-base font-bold text-blue-600">LD3 AI Chatbot</span>
            </a>
        </div>
        <div class="w-9 h-9 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center ring-2 ring-blue-100 cursor-pointer">
            <i class="fa-solid fa-user text-white text-xs"></i>
        </div>
    </header>

    <!-- ==================== MAIN CONTENT ==================== -->
    <main class="flex-1 overflow-y-auto">
        <div class="max-w-6xl mx-auto px-6 py-8">

            <!-- Page Header -->
            <div class="flex items-start justify-between mb-8">
                <div>
                    <h1 class="text-2xl font-bold text-gray-800">Quản lý tài liệu tri thức</h1>
                    <p class="text-sm text-gray-500 mt-1">Quản lý và tải lên các tài liệu làm cơ sở dữ liệu cho AI Chatbot của Trung tâm LD3.</p>
                </div>
                <button id="upload-trigger" type="button"
                        class="flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition shadow-sm">
                    <i class="fa-solid fa-plus text-xs"></i>
                    Tải lên tài liệu mới
                </button>
                <input id="upload-input" type="file"
                       accept="application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain"
                       class="hidden" />
            </div>

            <!-- Stats Cards -->
            <div class="grid grid-cols-4 gap-4 mb-8">
                <div class="bg-white rounded-lg border border-gray-200 p-5">
                    <div class="flex items-center gap-3 mb-2">
                        <div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center">
                            <i class="fa-regular fa-file-lines text-blue-500"></i>
                        </div>
                        <span class="text-sm text-gray-500">Tổng số tài liệu</span>
                    </div>
                    <p class="text-3xl font-bold text-gray-800">@Model.TotalCount</p>
                </div>
                <div class="bg-white rounded-lg border border-gray-200 p-5">
                    <div class="flex items-center gap-3 mb-2">
                        <div class="w-9 h-9 bg-green-50 rounded-lg flex items-center justify-center">
                            <i class="fa-solid fa-circle-check text-green-500"></i>
                        </div>
                        <span class="text-sm text-gray-500">Đã sẵn sàng</span>
                    </div>
                    <p class="text-3xl font-bold text-gray-800">@Model.ReadyCount</p>
                </div>
                <div class="bg-white rounded-lg border border-gray-200 p-5">
                    <div class="flex items-center gap-3 mb-2">
                        <div class="w-9 h-9 bg-yellow-50 rounded-lg flex items-center justify-center">
                            <i class="fa-regular fa-clock text-yellow-500"></i>
                        </div>
                        <span class="text-sm text-gray-500">Đang xử lý</span>
                    </div>
                    <p class="text-3xl font-bold text-gray-800">@Model.ProcessingCount</p>
                </div>
                <div class="bg-white rounded-lg border border-gray-200 p-5">
                    <div class="flex items-center gap-3 mb-2">
                        <div class="w-9 h-9 bg-red-50 rounded-lg flex items-center justify-center">
                            <i class="fa-solid fa-circle-exclamation text-red-500"></i>
                        </div>
                        <span class="text-sm text-gray-500">Lỗi hệ thống</span>
                    </div>
                    <p class="text-3xl font-bold text-gray-800">@Model.FailedCount</p>
                </div>
            </div>

            <!-- File Table -->
            <div class="bg-white rounded-lg border border-gray-200 mb-6">
                <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200">
                    <div class="flex items-center gap-2">
                        <i class="fa-regular fa-folder-open text-gray-400"></i>
                        <h2 class="text-base font-bold text-gray-800">Danh sách tệp tin đã tải lên</h2>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="relative">
                            <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
                            <input type="text" placeholder="Tìm kiếm tên file..."
                                   class="w-48 h-9 pl-9 pr-3 bg-gray-50 border border-gray-200 rounded-lg text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400 transition" />
                        </div>
                        <button class="flex items-center gap-1.5 px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition">
                            <i class="fa-solid fa-filter text-xs"></i> Bộ lọc
                        </button>
                    </div>
                </div>

                <table class="w-full">
                    <thead>
                        <tr class="border-b border-gray-100 bg-gray-50/50">
                            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Tên file</th>
                            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 py-3 w-32">Ngày tải lên</th>
                            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 py-3 w-28">Dung lượng</th>
                            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 py-3 w-28">Người tải</th>
                            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 py-3 w-36">Trạng thái xử lý</th>
                            <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3 w-28"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @if (Model.Documents.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="px-6 py-12 text-center text-sm text-gray-400">
                                    <i class="fa-regular fa-folder-open text-2xl mb-2 block"></i>
                                    Chưa có tài liệu nào. Bấm "Tải lên tài liệu mới" để bắt đầu.
                                </td>
                            </tr>
                        }
                        @foreach (var doc in Model.Documents)
                        {
                            var fileIcon = FileIcon(doc.MimeType);
                            var chip     = StatusChip(doc.Status);
                            var rowBg    = doc.Status == DocumentStatus.Failed ? "bg-red-50/30" : string.Empty;
                            <tr class="hover:bg-gray-50/50 transition @rowBg">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 @fileIcon.BgClass rounded-lg flex items-center justify-center shrink-0">
                                            <i class="@fileIcon.IconClass @fileIcon.TextClass text-sm"></i>
                                        </div>
                                        <span class="text-sm text-gray-700 font-medium truncate max-w-md" title="@doc.OriginalFileName">
                                            @doc.OriginalFileName
                                        </span>
                                    </div>
                                </td>
                                <td class="px-4 py-4 text-sm text-gray-500">@doc.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                <td class="px-4 py-4 text-sm text-gray-500">@FormatSize(doc.SizeBytes)</td>
                                <td class="px-4 py-4 text-sm text-gray-500 truncate max-w-[8rem]">@(doc.Uploader?.FullName ?? doc.UploaderId)</td>
                                <td class="px-4 py-4">
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 @chip.Wrap rounded-full text-xs font-medium"
                                          title="@doc.ErrorMessage">
                                        <i class="@chip.Icon text-[10px]"></i> @chip.Label
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center justify-end gap-2">
                                        <button class="text-gray-400 hover:text-blue-600 transition" title="Tải xuống">
                                            <i class="fa-solid fa-download text-sm"></i>
                                        </button>
                                        <button class="text-gray-400 hover:text-red-500 transition" title="Xóa">
                                            <i class="fa-regular fa-trash-can text-sm"></i>
                                        </button>
                                        <button class="text-gray-400 hover:text-gray-600 transition">
                                            <i class="fa-solid fa-ellipsis-vertical text-sm"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="flex items-center justify-between px-6 py-4 border-t border-gray-200">
                    <p class="text-sm text-gray-500">
                        Hiển thị @Model.Documents.Count trên tổng số @Model.TotalCount tài liệu
                    </p>
                </div>
            </div>

            <!-- Info Box -->
            <div class="bg-amber-50 border border-amber-200 rounded-lg p-5 flex gap-4">
                <div class="w-8 h-8 bg-amber-100 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                    <i class="fa-solid fa-circle-exclamation text-amber-500 text-sm"></i>
                </div>
                <div>
                    <p class="text-sm font-semibold text-amber-700 mb-1">Lưu ý về định dạng tệp</p>
                    <p class="text-sm text-amber-600 leading-relaxed">
                        Hệ thống hỗ trợ các định dạng <strong>.pdf</strong>, <strong>.docx</strong>, <strong>.txt</strong>
                        với dung lượng tối đa <strong>20MB</strong> mỗi tệp.
                        Tài liệu sau khi tải lên sẽ trải qua quá trình vector hóa tự động để AI có thể hiểu và trích xuất thông tin chính xác.
                        Thời gian xử lý trung bình từ 1-3 phút tùy vào độ dài văn bản.
                    </p>
                </div>
            </div>
        </div>
    </main>

    <!-- ==================== FOOTER ==================== -->
    <footer class="bg-white border-t border-gray-200 py-3 text-center shrink-0">
        <p class="text-xs text-gray-400">&copy; 2026 LD3 AI Chatbot</p>
    </footer>

    <!-- ==================== Upload script (POSTs to /api/documents) ==================== -->
    <script>
        (function () {
            const trigger = document.getElementById('upload-trigger');
            const input   = document.getElementById('upload-input');
            if (!trigger || !input) return;

            trigger.addEventListener('click', () => input.click());

            input.addEventListener('change', async () => {
                const file = input.files && input.files[0];
                if (!file) return;

                trigger.disabled = true;
                trigger.innerText = 'Đang tải lên...';

                try {
                    const fd = new FormData();
                    fd.append('file', file);

                    const res = await fetch('/api/documents', {
                        method: 'POST',
                        body: fd,
                        credentials: 'same-origin'
                    });

                    if (!res.ok) {
                        const txt = await res.text();
                        alert('Tải lên thất bại: ' + txt);
                    } else {
                        // 202 Accepted — row is Pending; reload to see it.
                        window.location.reload();
                    }
                } catch (err) {
                    alert('Lỗi kết nối: ' + err);
                } finally {
                    input.value = '';
                    trigger.disabled = false;
                }
            });
        })();
    </script>
</body>
</html>
