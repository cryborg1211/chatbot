@page
@model chatbot.Pages.Admin.DocumentsModel
@using chatbot.Models
@{
    ViewData["Title"] = "Tài liệu tri thức";
    ViewData["ActiveNav"] = "Documents";

    // ---- Local rendering helpers (kept inline — they're page-specific) ----

    (string Wrap, string Icon, string Label) StatusChip(DocumentStatus s) => s switch
    {
        DocumentStatus.Ready      => ("bg-green-50 text-green-700",  "fa-solid fa-circle-check",         "Đã sẵn sàng"),
        DocumentStatus.Processing => ("bg-yellow-50 text-yellow-700","fa-solid fa-spinner fa-spin",      "Đang vector hóa"),
        DocumentStatus.Pending    => ("bg-gray-100 text-gray-600",   "fa-regular fa-clock",              "Chờ xử lý"),
        DocumentStatus.Failed     => ("bg-red-100 text-red-600",     "fa-solid fa-circle-exclamation",   "Lỗi xử lý"),
        DocumentStatus.PartiallyIngested => ("bg-amber-50 text-amber-700", "fa-solid fa-triangle-exclamation", "Nhập một phần"),
        _                          => ("bg-gray-100 text-gray-600",  "fa-solid fa-circle",               s.ToString())
    };

    (string BgClass, string TextClass, string IconClass) FileIcon(string mime) => mime switch
    {
        "application/pdf"  => ("bg-red-50",   "text-red-500",   "fa-regular fa-file-pdf"),
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
                           => ("bg-blue-50",  "text-blue-500",  "fa-regular fa-file-word"),
        "text/plain"       => ("bg-gray-50",  "text-gray-500",  "fa-regular fa-file-lines"),
        _                  => ("bg-gray-50",  "text-gray-500",  "fa-regular fa-file")
    };

    string FormatSize(long bytes) => bytes switch
    {
        < 1024              => $"{bytes} B",
        < 1024L * 1024      => $"{bytes / 1024.0:F1} KB",
        _                   => $"{bytes / (1024.0 * 1024.0):F1} MB"
    };
}

<!-- Page Header -->
<div class="flex items-start justify-between mb-8">
    <div>
        <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-100">Quản lý tài liệu tri thức</h1>
        <p class="text-sm text-gray-500 mt-1 dark:text-gray-400">Quản lý và tải lên các tài liệu làm cơ sở dữ liệu cho AI Chatbot của Trung tâm LD3.</p>
    </div>
    <button id="upload-trigger" type="button"
            class="flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition shadow-sm">
        <i class="fa-solid fa-plus text-xs"></i>
        Tải lên tài liệu mới
    </button>
    <input id="upload-input" type="file" multiple
        accept="application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword,text/plain"
        class="hidden" />
</div>

<!-- Stats Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
    <div class="bg-white rounded-lg border border-gray-200 p-5 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center dark:bg-blue-900/30">
                <i class="fa-regular fa-file-lines text-blue-500"></i>
            </div>
            <span class="text-sm text-gray-500 dark:text-gray-400">Tổng số tài liệu</span>
        </div>
        <p class="text-3xl font-bold text-gray-800 dark:text-gray-100">@Model.TotalCount</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-5 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 bg-green-50 rounded-lg flex items-center justify-center dark:bg-green-900/30">
                <i class="fa-solid fa-circle-check text-green-500"></i>
            </div>
            <span class="text-sm text-gray-500 dark:text-gray-400">Đã sẵn sàng</span>
        </div>
        <p class="text-3xl font-bold text-gray-800 dark:text-gray-100">@Model.ReadyCount</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-5 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 bg-yellow-50 rounded-lg flex items-center justify-center dark:bg-yellow-900/30">
                <i class="fa-regular fa-clock text-yellow-500"></i>
            </div>
            <span class="text-sm text-gray-500 dark:text-gray-400">Đang xử lý</span>
        </div>
        <p class="text-3xl font-bold text-gray-800 dark:text-gray-100">@Model.ProcessingCount</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-5 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 bg-red-50 rounded-lg flex items-center justify-center dark:bg-red-900/30">
                <i class="fa-solid fa-circle-exclamation text-red-500"></i>
            </div>
            <span class="text-sm text-gray-500 dark:text-gray-400">Lỗi hệ thống</span>
        </div>
        <p class="text-3xl font-bold text-gray-800 dark:text-gray-100">@Model.FailedCount</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-5 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 bg-amber-50 rounded-lg flex items-center justify-center dark:bg-amber-900/30">
                <i class="fa-solid fa-triangle-exclamation text-amber-500"></i>
            </div>
            <span class="text-sm text-gray-500 dark:text-gray-400">Nhập một phần</span>
        </div>
        <p class="text-3xl font-bold text-gray-800 dark:text-gray-100">@Model.PartiallyIngestedCount</p>
    </div>
</div>

<!-- File Table -->
<div class="bg-white rounded-lg border border-gray-200 mb-6 dark:bg-gray-800 dark:border-gray-700">
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <div class="flex items-center gap-2">
            <i class="fa-regular fa-folder-open text-gray-400"></i>
            <h2 class="text-base font-bold text-gray-800 dark:text-gray-100">Danh sách tệp tin đã tải lên</h2>
        </div>
        <div class="flex items-center gap-3">
            <div class="relative">
                <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
                <input type="text" placeholder="Tìm kiếm tên file..."
                       class="w-48 h-9 pl-9 pr-3 bg-gray-50 border border-gray-200 rounded-lg text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400 transition dark:bg-gray-900 dark:border-gray-600 dark:text-gray-100" />
            </div>
            <button class="flex items-center gap-1.5 px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700/50">
                <i class="fa-solid fa-filter text-xs"></i> Bộ lọc
            </button>
        </div>
    </div>

    <table class="w-full">
        <thead>
            <tr class="border-b border-gray-100 bg-gray-50/50 dark:border-gray-700 dark:bg-gray-900/30">
                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Tên file</th>
                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 py-3 w-32">Ngày tải lên</th>
                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 py-3 w-28">Dung lượng</th>
                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 py-3 w-28">Người tải</th>
                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 py-3 w-36">Trạng thái xử lý</th>
                <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3 w-28"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
            @if (Model.Documents.Count == 0)
            {
                <tr>
                    <td colspan="6" class="px-6 py-12 text-center text-sm text-gray-400">
                        <i class="fa-regular fa-folder-open text-2xl mb-2 block"></i>
                        Chưa có tài liệu nào. Bấm "Tải lên tài liệu mới" để bắt đầu.
                    </td>
                </tr>
            }
            @foreach (var doc in Model.Documents)
            {
                var fileIcon = FileIcon(doc.MimeType);
                var chip     = StatusChip(doc.Status);
                var rowBg    = doc.Status == DocumentStatus.Failed ? "bg-red-50/30" : string.Empty;
                <tr data-doc-id="@doc.Id" class="hover:bg-gray-50/50 transition dark:hover:bg-gray-700/30 @rowBg">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 @fileIcon.BgClass rounded-lg flex items-center justify-center shrink-0">
                                <i class="@fileIcon.IconClass @fileIcon.TextClass text-sm"></i>
                            </div>
                            <span class="text-sm text-gray-700 font-medium truncate max-w-md dark:text-gray-200" title="@doc.OriginalFileName">
                                @doc.OriginalFileName
                            </span>
                        </div>
                    </td>
                    <td class="px-4 py-4 text-sm text-gray-500">@doc.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                    <td class="px-4 py-4 text-sm text-gray-500">@FormatSize(doc.SizeBytes)</td>
                    <td class="px-4 py-4 text-sm text-gray-500 truncate max-w-[8rem]">@(doc.Uploader?.FullName ?? doc.UploaderId)</td>
                    <td class="px-4 py-4" data-status-cell>
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 @chip.Wrap rounded-full text-xs font-medium"
                              title="@doc.ErrorMessage">
                            <i class="@chip.Icon text-[10px]"></i> @chip.Label
                        </span>
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center justify-end gap-2">
                            <a href="/api/documents/@doc.Id/download" class="text-gray-400 hover:text-blue-600 transition" title="Tải xuống">
                                <i class="fa-solid fa-download text-sm"></i>
                            </a>
                            <button type="button"
                                    data-delete-id="@doc.Id"
                                    data-delete-name="@doc.OriginalFileName"
                                    class="text-gray-400 hover:text-red-500 transition" title="Xóa">
                                <i class="fa-regular fa-trash-can text-sm"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="flex items-center justify-between px-6 py-4 border-t border-gray-200 dark:border-gray-700">
        <p class="text-sm text-gray-500">
            Hiển thị @Model.Documents.Count trên tổng số @Model.TotalCount tài liệu
        </p>
    </div>
</div>

<!-- Info Box -->
<div class="bg-amber-50 border border-amber-200 rounded-lg p-5 flex gap-4 dark:bg-amber-900/20 dark:border-amber-800">
    <div class="w-8 h-8 bg-amber-100 rounded-full flex items-center justify-center shrink-0 mt-0.5 dark:bg-amber-900/40">
        <i class="fa-solid fa-circle-exclamation text-amber-500 text-sm"></i>
    </div>
    <div>
        <p class="text-sm font-semibold text-amber-700 mb-1 dark:text-amber-300">Lưu ý về định dạng tệp</p>
        <p class="text-sm text-amber-600 leading-relaxed dark:text-amber-400">
            Hệ thống hỗ trợ các định dạng <strong>.pdf</strong>, <strong>.docx</strong>, <strong>.txt</strong>
            với dung lượng tối đa <strong>20MB</strong> mỗi tệp.
            Tài liệu sau khi tải lên sẽ trải qua quá trình vector hóa tự động để AI có thể hiểu và trích xuất thông tin chính xác.
            Thời gian xử lý trung bình từ 1-3 phút tùy vào độ dài văn bản.
        </p>
    </div>
</div>

@section Scripts {
    <!-- SignalR real-time status updates -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        (function () {
            if (typeof signalR === "undefined") return;

            const visibleIds = new Set(
                Array.from(document.querySelectorAll("[data-doc-id]"))
                     .map(el => (el.dataset.docId || "").toLowerCase())
            );
            if (visibleIds.size === 0) return;

            const conn = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/document")
                .withAutomaticReconnect()
                .build();

            let reloadTimer = null;
            function scheduleReload() {
                if (reloadTimer) clearTimeout(reloadTimer);
                reloadTimer = setTimeout(() => window.location.reload(), 800);
            }

            conn.on("DocumentUpdated", (documentId, newStatus) => {
                const id = (documentId || "").toLowerCase();
                if (!visibleIds.has(id)) return;
                scheduleReload();
            });

            conn.start().catch(err => console.warn("signalr_start_failed", err));
        })();
    </script>

    <!-- Delete (DELETE /api/documents/{id}) -->
    <script>
        (function () {
            function getAntiForgeryToken() {
                const el = document.querySelector('input[name="__RequestVerificationToken"]');
                return el ? el.value : null;
            }

            document.querySelectorAll("[data-delete-id]").forEach((btn) => {
                btn.addEventListener("click", async () => {
                    const docId = btn.dataset.deleteId;
                    const name  = btn.dataset.deleteName || "tài liệu này";
                    if (!docId) return;

                    if (!confirm(`Bạn có chắc muốn xoá "${name}" và toàn bộ vector liên quan? Hành động này không thể hoàn tác.`)) {
                        return;
                    }

                    btn.disabled = true;
                    btn.classList.add("opacity-50", "cursor-not-allowed");
                    const icon = btn.querySelector("i");
                    const originalIconClass = icon ? icon.className : null;
                    if (icon) icon.className = "fa-solid fa-spinner fa-spin text-sm";

                    try {
                        const headers = { "Accept": "application/json" };
                        const token   = getAntiForgeryToken();
                        if (token) headers["RequestVerificationToken"] = token;

                        const res = await fetch(`/api/documents/${encodeURIComponent(docId)}`, {
                            method:      "DELETE",
                            headers:     headers,
                            credentials: "same-origin",
                        });

                        if (!res.ok) {
                            const body = await res.text().catch(() => "");
                            alert(`Xoá thất bại (HTTP ${res.status}): ${body || "không rõ"}`);
                            if (icon && originalIconClass) icon.className = originalIconClass;
                            btn.disabled = false;
                            btn.classList.remove("opacity-50", "cursor-not-allowed");
                            return;
                        }

                        const row = btn.closest("tr[data-doc-id]");
                        if (row) {
                            row.style.transition = "opacity 200ms ease";
                            row.style.opacity = "0";
                            setTimeout(() => row.remove(), 220);
                        }
                    } catch (err) {
                        console.error("delete_failed", err);
                        alert("Lỗi kết nối tới máy chủ khi xoá tài liệu.");
                        if (icon && originalIconClass) icon.className = originalIconClass;
                        btn.disabled = false;
                        btn.classList.remove("opacity-50", "cursor-not-allowed");
                    }
                });
            });
        })();
    </script>

    <!-- Upload (POST /api/documents) -->
    <script>
        (function () {
            const trigger = document.getElementById('upload-trigger');
            const input   = document.getElementById('upload-input');
            if (!trigger || !input) return;

            const originalLabel = trigger.innerHTML;

            trigger.addEventListener('click', () => input.click());

            input.addEventListener('change', async () => {
                const files = input.files ? Array.from(input.files) : [];
                if (files.length === 0) return;

                const count = files.length;
                trigger.disabled = true;
                trigger.classList.add('opacity-70', 'cursor-not-allowed');
                trigger.innerHTML =
                    `<i class="fa-solid fa-spinner fa-spin text-xs"></i> Đang tải ${count} tệp...`;

                try {
                    const fd = new FormData();
                    for (const f of files) fd.append('files', f, f.name);

                    const res = await fetch('/api/documents', {
                        method:      'POST',
                        body:        fd,
                        credentials: 'same-origin',
                        headers:     { 'Accept': 'application/json' },
                    });

                    if (!res.ok) {
                        const txt = await res.text().catch(() => '');
                        alert(`Tải lên thất bại (HTTP ${res.status}):\n${txt}`);
                        return;
                    }

                    let summary = null;
                    try { summary = await res.json(); } catch { /* ignore */ }

                    if (summary && Array.isArray(summary.items)) {
                        const failed = summary.items
                            .filter(i => !i.success)
                            .map(i => `• ${i.fileName}: ${i.error || 'lỗi'}`);

                        if (failed.length === 0) {
                            window.location.reload();
                            return;
                        }

                        alert(
                            `Đã tải lên ${summary.totalAccepted}/${count} tệp.\n\n` +
                            `Thất bại:\n${failed.join('\n')}`
                        );
                        window.location.reload();
                    } else {
                        window.location.reload();
                    }
                } catch (err) {
                    console.error('upload_failed', err);
                    alert('Lỗi kết nối tới máy chủ.');
                } finally {
                    input.value = '';
                    trigger.disabled = false;
                    trigger.classList.remove('opacity-70', 'cursor-not-allowed');
                    trigger.innerHTML = originalLabel;
                }
            });
        })();
    </script>
}
