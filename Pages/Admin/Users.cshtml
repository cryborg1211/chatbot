@page
@model chatbot.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Quản lý người dùng";
    ViewData["ActiveNav"] = "Users";

    (string Bg, string Text, string Label) StatusChip(chatbot.Pages.Admin.UserStatus s) => s switch
    {
        chatbot.Pages.Admin.UserStatus.Active  => ("bg-green-50",  "text-green-600",  "Đã kích hoạt"),
        chatbot.Pages.Admin.UserStatus.Pending => ("bg-yellow-50", "text-yellow-600", "Chờ phê duyệt"),
        chatbot.Pages.Admin.UserStatus.Locked  => ("bg-red-50",    "text-red-600",    "Đã từ chối / khoá"),
        _                                       => ("bg-gray-50",   "text-gray-600",   "?")
    };

    string AvatarPalette(string id)
    {
        // deterministic colour by user id hash
        var palettes = new[] {
            "bg-blue-100 text-blue-600", "bg-pink-100 text-pink-600",
            "bg-green-100 text-green-600", "bg-amber-100 text-amber-600",
            "bg-violet-100 text-violet-600", "bg-indigo-100 text-indigo-600",
        };
        var idx = Math.Abs(id?.GetHashCode() ?? 0) % palettes.Length;
        return palettes[idx];
    }
}

<!-- Page Header -->
<div class="flex items-start justify-between mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-800">Quản lý người dùng</h1>
        <p class="text-sm text-gray-500 mt-1">Phê duyệt, phân quyền và giám sát trạng thái người dùng trong hệ thống.</p>
    </div>
</div>

<!-- Stats Cards -->
<div class="grid grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-lg border border-gray-200 p-5">
        <div class="flex items-center justify-between mb-3">
            <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-users text-blue-500"></i>
            </div>
        </div>
        <p class="text-sm text-gray-500">Tổng người dùng</p>
        <p class="text-3xl font-bold text-gray-800 mt-1">@Model.TotalUsers</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-5">
        <div class="flex items-center justify-between mb-3">
            <div class="w-10 h-10 bg-green-50 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-circle-check text-green-500"></i>
            </div>
        </div>
        <p class="text-sm text-gray-500">Đã kích hoạt</p>
        <p class="text-3xl font-bold text-gray-800 mt-1">@Model.ActiveCount</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-5">
        <div class="flex items-center justify-between mb-3">
            <div class="w-10 h-10 bg-yellow-50 rounded-lg flex items-center justify-center">
                <i class="fa-regular fa-clock text-yellow-500"></i>
            </div>
        </div>
        <p class="text-sm text-gray-500">Chờ phê duyệt</p>
        <p class="text-3xl font-bold text-gray-800 mt-1">@Model.PendingCount</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-5">
        <div class="flex items-center justify-between mb-3">
            <div class="w-10 h-10 bg-red-50 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-lock text-red-500"></i>
            </div>
        </div>
        <p class="text-sm text-gray-500">Bị khoá</p>
        <p class="text-3xl font-bold text-gray-800 mt-1">@Model.LockedCount</p>
    </div>
</div>

<!-- User Table -->
<div class="bg-white rounded-lg border border-gray-200">
    <!-- Table Header Bar (search + dept filter via GET form) -->
    <form method="get" class="flex items-center justify-between px-6 py-4 border-b border-gray-200 gap-3">
        <div class="flex items-center gap-3 flex-1">
            <h2 class="text-lg font-bold text-gray-800 whitespace-nowrap">Danh sách người dùng</h2>
            <div class="relative">
                <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
                <input type="text" name="Search" value="@Model.Search" placeholder="Tìm theo tên hoặc email..."
                       class="w-64 h-9 pl-9 pr-3 bg-gray-50 border border-gray-200 rounded-lg text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400 transition" />
            </div>
            <select name="DepartmentId" class="h-9 px-3 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400">
                <option value="">Tất cả phòng ban</option>
                @foreach (var d in Model.Departments)
                {
                    <option value="@d.Id" selected="@(Model.DepartmentId == d.Id)">@d.Name</option>
                }
            </select>
            <button type="submit" class="px-4 h-9 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition">Lọc</button>
        </div>
        <span class="text-sm text-gray-500">@Model.TotalCount kết quả</span>
    </form>

    <table class="w-full">
        <thead>
            <tr class="border-b border-gray-100 bg-gray-50/50">
                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Tên người dùng</th>
                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Email</th>
                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Phòng ban</th>
                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Trạng thái</th>
                <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Thao tác</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="5" class="px-6 py-12 text-center text-sm text-gray-400">Không có người dùng nào khớp bộ lọc.</td></tr>
            }
            @foreach (var u in Model.Items)
            {
                var chip = StatusChip(u.Status);
                <tr class="hover:bg-gray-50/50 transition">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <div class="w-9 h-9 rounded-full @AvatarPalette(u.Id) flex items-center justify-center shrink-0">
                                <i class="fa-solid fa-user text-xs"></i>
                            </div>
                            <p class="text-sm font-semibold text-gray-800">@u.FullName</p>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-600">@u.Email</td>
                    <td class="px-6 py-4">
                        <span class="px-2.5 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-medium whitespace-nowrap" title="@u.DepartmentId">@u.DepartmentName</span>
                    </td>
                    <td class="px-6 py-4">
                        <span class="text-sm font-medium @chip.Text">@chip.Label</span>
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center justify-end gap-2">
                            @if (u.Status == chatbot.Pages.Admin.UserStatus.Pending)
                            {
                                <form method="post" asp-page-handler="Approve" asp-route-id="@u.Id" class="inline">
                                    <input type="hidden" name="Search" value="@Model.Search" />
                                    <input type="hidden" name="DepartmentId" value="@Model.DepartmentId" />
                                    <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                                    <button type="submit" class="px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition">Phê duyệt</button>
                                </form>
                                <form method="post" asp-page-handler="Reject" asp-route-id="@u.Id" class="inline">
                                    <input type="hidden" name="Search" value="@Model.Search" />
                                    <input type="hidden" name="DepartmentId" value="@Model.DepartmentId" />
                                    <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                                    <button type="submit" class="px-3 py-1.5 border border-gray-300 text-gray-600 rounded-lg text-sm font-medium hover:bg-gray-50 transition">Từ chối</button>
                                </form>
                            }
                            else if (u.Status == chatbot.Pages.Admin.UserStatus.Locked)
                            {
                                <form method="post" asp-page-handler="Activate" asp-route-id="@u.Id" class="inline">
                                    <input type="hidden" name="Search" value="@Model.Search" />
                                    <input type="hidden" name="DepartmentId" value="@Model.DepartmentId" />
                                    <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                                    <button type="submit" class="px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white rounded-lg text-sm font-medium transition">Kích hoạt lại</button>
                                </form>
                            }
                            else
                            {
                                <form method="post" asp-page-handler="Reject" asp-route-id="@u.Id" class="inline">
                                    <input type="hidden" name="Search" value="@Model.Search" />
                                    <input type="hidden" name="DepartmentId" value="@Model.DepartmentId" />
                                    <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                                    <button type="submit" class="px-3 py-1.5 border border-gray-300 text-gray-600 rounded-lg text-sm font-medium hover:bg-gray-50 transition" title="Khoá tài khoản">Khoá</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Pagination -->
    <div class="flex items-center justify-between px-6 py-4 border-t border-gray-200">
        <p class="text-sm text-gray-400 italic">Trang @Model.PageNumber / @Model.TotalPages</p>
        <div class="flex items-center gap-1">
            @{
                var prev = Math.Max(1, Model.PageNumber - 1);
                var next = Math.Min(Model.TotalPages, Model.PageNumber + 1);
            }
            <a href="?Search=@Model.Search&DepartmentId=@Model.DepartmentId&PageNumber=@prev"
               class="px-3 py-1.5 text-sm text-gray-600 rounded-lg border border-gray-300 hover:bg-gray-50 transition">Trước</a>
            <span class="w-8 h-8 flex items-center justify-center rounded-lg text-sm bg-blue-600 text-white font-medium">@Model.PageNumber</span>
            <a href="?Search=@Model.Search&DepartmentId=@Model.DepartmentId&PageNumber=@next"
               class="px-3 py-1.5 text-sm text-gray-600 rounded-lg border border-gray-300 hover:bg-gray-50 transition">Sau</a>
        </div>
    </div>
</div>
