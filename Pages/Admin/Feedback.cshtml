@page
@model chatbot.Pages.Admin.FeedbackModel
@using chatbot.Models
@{
    ViewData["Title"] = "Phản hồi & Đánh giá";
    ViewData["ActiveNav"] = "Feedback";

    string Truncate(string s, int n) => string.IsNullOrEmpty(s) ? string.Empty : (s.Length <= n ? s : s[..n] + "…");
}

<!-- Page Header -->
<div class="flex items-start justify-between mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-100">Phản hồi &amp; Đánh giá</h1>
        <p class="text-sm text-gray-500 mt-1 dark:text-gray-400">Theo dõi và phân tích chất lượng tương tác giữa người dùng và hệ thống AI.</p>
    </div>
    <form method="get" class="flex items-center gap-3">
        <div class="flex items-center gap-2 px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-600 dark:border-gray-600 dark:text-gray-300">
            <i class="fa-solid fa-filter text-xs text-gray-400"></i>
            <span>Lọc theo:</span>
            <select name="Filter" onchange="this.form.submit()" class="bg-transparent font-medium text-gray-700 focus:outline-none cursor-pointer dark:text-gray-200">
                <option value="all"  selected="@(Model.Filter == "all")">Tất cả</option>
                <option value="up"   selected="@(Model.Filter == "up")">Hài lòng</option>
                <option value="down" selected="@(Model.Filter == "down")">Không hài lòng</option>
            </select>
        </div>
    </form>
</div>

<!-- Stats row -->
<div class="grid grid-cols-3 gap-4 mb-6">
    <div class="bg-white rounded-lg border border-gray-200 p-5 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center">
                <i class="fa-regular fa-comments text-blue-500"></i>
            </div>
            <span class="text-sm text-gray-500">Tổng phản hồi</span>
        </div>
        <p class="text-3xl font-bold text-gray-800 dark:text-gray-100">@(Model.ThumbsUpCount + Model.ThumbsDownCount)</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-5 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 bg-green-50 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-thumbs-up text-green-500"></i>
            </div>
            <span class="text-sm text-gray-500">Hài lòng</span>
        </div>
        <p class="text-3xl font-bold text-gray-800 dark:text-gray-100">@Model.ThumbsUpCount</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-5 dark:bg-gray-800 dark:border-gray-700">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 bg-red-50 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-thumbs-down text-red-500"></i>
            </div>
            <span class="text-sm text-gray-500">Không hài lòng</span>
        </div>
        <p class="text-3xl font-bold text-gray-800 dark:text-gray-100">@Model.ThumbsDownCount</p>
    </div>
</div>

<!-- Feedback table -->
<div class="bg-white rounded-lg border border-gray-200 dark:bg-gray-800 dark:border-gray-700">
    <table class="w-full">
        <thead>
            <tr class="border-b border-gray-200 bg-gray-50/50 dark:border-gray-700 dark:bg-gray-900/30">
                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3 w-48">Người dùng</th>
                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3 w-56">Câu hỏi</th>
                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Câu trả lời của AI</th>
                <th class="text-center text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 py-3 w-36">Đánh giá</th>
                <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3 w-32">Thời gian</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="5" class="px-6 py-12 text-center text-sm text-gray-400">Chưa có phản hồi nào.</td></tr>
            }
            @foreach (var f in Model.Items)
            {
                var up = f.Rating == FeedbackRating.ThumbsUp;
                <tr class="hover:bg-gray-50/50 transition align-top dark:hover:bg-gray-700/30">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <div class="w-9 h-9 rounded-full bg-blue-100 flex items-center justify-center shrink-0">
                                <i class="fa-solid fa-user text-blue-600 text-xs"></i>
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-gray-800 dark:text-gray-100">@f.UserFullName</p>
                                <p class="text-xs text-gray-400">@f.DepartmentId</p>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex gap-2">
                            <i class="fa-regular fa-comment text-gray-300 mt-0.5 shrink-0"></i>
                            <p class="text-sm text-gray-600 italic dark:text-gray-300" title="@f.Question">"@Truncate(f.Question, 120)"</p>
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        <div class="bg-blue-50/60 border border-blue-100 rounded-lg p-3 text-sm text-gray-700 leading-relaxed dark:bg-blue-900/20 dark:border-blue-800 dark:text-gray-200" title="@f.Answer">
                            @Truncate(f.Answer, 240)
                        </div>
                    </td>
                    <td class="px-4 py-4 text-center">
                        @if (up)
                        {
                            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-green-50 text-green-700 rounded-full text-xs font-semibold">
                                <i class="fa-solid fa-thumbs-up text-[10px]"></i> HÀI LÒNG
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1.5 bg-red-50 text-red-600 rounded-full text-xs font-semibold">
                                <i class="fa-solid fa-thumbs-down text-[10px]"></i> KHÔNG HÀI LÒNG
                            </span>
                        }
                    </td>
                    <td class="px-6 py-4 text-right">
                        <span class="text-sm text-gray-400 whitespace-nowrap">
                            <i class="fa-regular fa-clock text-xs mr-1"></i>@f.At.ToLocalTime().ToString("dd/MM HH:mm")
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="flex items-center justify-between px-6 py-4 border-t border-gray-200 dark:border-gray-700">
        <p class="text-sm text-gray-500">Trang @Model.PageNumber / @Model.TotalPages · @Model.TotalCount mục</p>
        @{
            var prev = Math.Max(1, Model.PageNumber - 1);
            var next = Math.Min(Model.TotalPages, Model.PageNumber + 1);
        }
        <div class="flex items-center gap-1">
            <a href="?Filter=@Model.Filter&PageNumber=@prev"
               class="px-3 py-1.5 text-sm text-gray-600 rounded-lg border border-gray-300 hover:bg-gray-50 transition dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-700/50">Trước</a>
            <span class="w-8 h-8 flex items-center justify-center rounded-lg text-sm bg-blue-600 text-white font-medium">@Model.PageNumber</span>
            <a href="?Filter=@Model.Filter&PageNumber=@next"
               class="px-3 py-1.5 text-sm text-gray-600 rounded-lg border border-gray-300 hover:bg-gray-50 transition dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-700/50">Sau</a>
        </div>
    </div>
</div>
