@page "/admin"
@model chatbot.Pages.Admin.AdminIndexModel
@{
    Layout = null;

    (string Bg, string Text, string Label) StatusChip(chatbot.Pages.Admin.UserStatus s) => s switch
    {
        chatbot.Pages.Admin.UserStatus.Active  => ("bg-green-50",  "text-green-600",  "Đã kích hoạt"),
        chatbot.Pages.Admin.UserStatus.Pending => ("bg-yellow-50", "text-yellow-600", "Chờ phê duyệt"),
        chatbot.Pages.Admin.UserStatus.Locked  => ("bg-red-50",    "text-red-600",    "Đã từ chối / khoá"),
        _                                       => ("bg-gray-50",   "text-gray-600",   "?")
    };

    string AvatarPalette(string id)
    {
        var palettes = new[] {
            "bg-blue-100 text-blue-600", "bg-pink-100 text-pink-600",
            "bg-green-100 text-green-600", "bg-amber-100 text-amber-600",
            "bg-violet-100 text-violet-600", "bg-indigo-100 text-indigo-600",
        };
        var idx = Math.Abs(id?.GetHashCode() ?? 0) % palettes.Length;
        return palettes[idx];
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trang quản trị - LD3 AI Chatbot</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body class="bg-gray-50 text-gray-800 antialiased">
    <div class="flex h-screen overflow-hidden">

        <!-- ==================== LEFT SIDEBAR ==================== -->
        <aside class="w-64 bg-white border-r border-gray-200 flex flex-col shrink-0">

            <!-- Logo -->
            <div class="h-16 flex items-center gap-2.5 px-5 border-b border-gray-100">
                <div class="w-9 h-9 rounded-full bg-blue-50 flex items-center justify-center shrink-0">
                    <i class="fa-solid fa-heart-pulse text-blue-500 text-lg"></i>
                </div>
                <span class="text-lg font-bold text-blue-600 tracking-tight">LD3 AI Chatbot</span>
            </div>

            <!-- New Chat Button -->
            <div class="px-4 pt-4 pb-2">
                <a href="/Chat"
                   class="flex items-center justify-center gap-2 h-10 w-full border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 active:bg-gray-100 transition cursor-pointer">
                    <i class="fa-solid fa-plus text-xs"></i>
                    <span>Cuộc trò chuyện mới</span>
                </a>
            </div>

            <!-- Scrollable Middle -->
            <div class="flex-1 overflow-y-auto px-3 pt-2">

                <!-- Admin Navigation -->
                <p class="px-2 mb-1.5 text-[11px] font-semibold uppercase tracking-wider text-gray-400">Quản trị</p>
                <nav class="space-y-0.5 mb-4">
                    <a href="/admin"
                       class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium bg-blue-50 text-blue-700">
                        <i class="fa-solid fa-users text-sm w-5 text-center text-blue-500"></i>
                        <span>Quản lý người dùng</span>
                    </a>
                    <a href="/Admin/Feedback"
                       class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">
                        <i class="fa-regular fa-comment-dots text-sm w-5 text-center text-gray-400"></i>
                        <span>Phản hồi &amp; Đánh giá</span>
                    </a>
                    <a href="/Admin/Logs"
                       class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">
                        <i class="fa-solid fa-clock-rotate-left text-sm w-5 text-center text-gray-400"></i>
                        <span>Nhật ký hệ thống</span>
                    </a>
                </nav>

            </div>

            <!-- Bottom: Settings & Logout -->
            <div class="border-t border-gray-200 px-3 py-3 space-y-0.5">
                <span class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-gray-400 cursor-not-allowed opacity-50" title="Chưa khả dụng">
                    <i class="fa-solid fa-gear text-gray-400 text-sm w-5 text-center"></i>
                    <span>Cài đặt hệ thống</span>
                </span>
                <form method="post" action="/Account/Logout">
                    <button type="submit"
                            class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-red-500 hover:bg-red-50 transition w-full">
                        <i class="fa-solid fa-right-from-bracket text-red-400 text-sm w-5 text-center"></i>
                        <span>Đăng xuất</span>
                    </button>
                </form>
            </div>
        </aside>

        <!-- ==================== RIGHT AREA ==================== -->
        <div class="flex-1 flex flex-col min-w-0">

            <!-- Top Header -->
            <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-6 shrink-0">
                <div></div>

                <!-- Right: Notification + Profile -->
                <div class="flex items-center gap-4">
                    <span class="relative w-9 h-9 flex items-center justify-center text-gray-400 cursor-not-allowed opacity-50" title="Chưa khả dụng">
                        <i class="fa-regular fa-bell text-lg"></i>
                    </span>
                    <div class="h-6 w-px bg-gray-200"></div>
                    <a href="/Chat" class="flex items-center gap-3 cursor-pointer hover:opacity-80 transition" title="Về trang chat">
                        <div class="text-right leading-tight">
                            <p class="text-sm font-medium text-gray-700">@Model.FullName</p>
                            <p class="text-xs text-gray-400">Quản trị viên</p>
                        </div>
                        <div class="w-9 h-9 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center ring-2 ring-blue-100">
                            <i class="fa-solid fa-user text-white text-xs"></i>
                        </div>
                    </a>
                </div>
            </header>

            <!-- Page Content -->
            <main class="flex-1 overflow-y-auto p-6">

                <!-- Page Header -->
                <div class="flex items-start justify-between mb-6">
                    <div>
                        <h1 class="text-2xl font-bold text-gray-800">Quản lý người dùng</h1>
                        <p class="text-sm text-gray-500 mt-1">Phê duyệt, phân quyền và giám sát trạng thái người dùng trong hệ thống.</p>
                    </div>
                </div>

                <!-- Stats Cards -->
                <div class="grid grid-cols-4 gap-4 mb-8">
                    <div class="bg-white rounded-lg border border-gray-200 p-5">
                        <div class="flex items-center justify-between mb-3">
                            <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center">
                                <i class="fa-solid fa-users text-blue-500"></i>
                            </div>
                        </div>
                        <p class="text-sm text-gray-500">Tổng người dùng</p>
                        <p class="text-3xl font-bold text-gray-800 mt-1">@Model.TotalUsers</p>
                    </div>
                    <div class="bg-white rounded-lg border border-gray-200 p-5">
                        <div class="flex items-center justify-between mb-3">
                            <div class="w-10 h-10 bg-green-50 rounded-lg flex items-center justify-center">
                                <i class="fa-solid fa-circle-check text-green-500"></i>
                            </div>
                        </div>
                        <p class="text-sm text-gray-500">Đã kích hoạt</p>
                        <p class="text-3xl font-bold text-gray-800 mt-1">@Model.ActiveCount</p>
                    </div>
                    <div class="bg-white rounded-lg border border-gray-200 p-5">
                        <div class="flex items-center justify-between mb-3">
                            <div class="w-10 h-10 bg-yellow-50 rounded-lg flex items-center justify-center">
                                <i class="fa-regular fa-clock text-yellow-500"></i>
                            </div>
                        </div>
                        <p class="text-sm text-gray-500">Chờ phê duyệt</p>
                        <p class="text-3xl font-bold text-gray-800 mt-1">@Model.PendingCount</p>
                    </div>
                    <div class="bg-white rounded-lg border border-gray-200 p-5">
                        <div class="flex items-center justify-between mb-3">
                            <div class="w-10 h-10 bg-red-50 rounded-lg flex items-center justify-center">
                                <i class="fa-solid fa-lock text-red-500"></i>
                            </div>
                        </div>
                        <p class="text-sm text-gray-500">Bị khoá</p>
                        <p class="text-3xl font-bold text-gray-800 mt-1">@Model.LockedCount</p>
                    </div>
                </div>

                <!-- User Table -->
                <div class="bg-white rounded-lg border border-gray-200">
                    <!-- Table Header Bar (search + dept filter via GET form) -->
                    <form method="get" class="flex items-center justify-between px-6 py-4 border-b border-gray-200 gap-3">
                        <div class="flex items-center gap-3 flex-1">
                            <h2 class="text-lg font-bold text-gray-800 whitespace-nowrap">Danh sách người dùng</h2>
                            <div class="relative">
                                <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
                                <input type="text" name="Search" value="@Model.Search" placeholder="Tìm theo tên hoặc email..."
                                       class="w-64 h-9 pl-9 pr-3 bg-gray-50 border border-gray-200 rounded-lg text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400 transition" />
                            </div>
                            <select name="DepartmentId" class="h-9 px-3 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400">
                                <option value="">Tất cả phòng ban</option>
                                @foreach (var d in Model.Departments)
                                {
                                    <option value="@d.Id" selected="@(Model.DepartmentId == d.Id)">@d.Name</option>
                                }
                            </select>
                            <button type="submit" class="px-4 h-9 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition">Lọc</button>
                        </div>
                        <span class="text-sm text-gray-500">@Model.TotalCount kết quả</span>
                    </form>

                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-gray-100 bg-gray-50/50">
                                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Tên người dùng</th>
                                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Email</th>
                                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Phòng ban</th>
                                <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Trạng thái</th>
                                <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wider px-6 py-3">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @if (Model.Items.Count == 0)
                            {
                                <tr><td colspan="5" class="px-6 py-12 text-center text-sm text-gray-400">Không có người dùng nào khớp bộ lọc.</td></tr>
                            }
                            @foreach (var u in Model.Items)
                            {
                                var chip = StatusChip(u.Status);
                                <tr class="hover:bg-gray-50/50 transition">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-9 h-9 rounded-full @AvatarPalette(u.Id) flex items-center justify-center shrink-0">
                                                <i class="fa-solid fa-user text-xs"></i>
                                            </div>
                                            <p class="text-sm font-semibold text-gray-800">@u.FullName</p>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-gray-600">@u.Email</td>
                                    <td class="px-6 py-4">
                                        <span class="px-2.5 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-medium whitespace-nowrap" title="@u.DepartmentId">@u.DepartmentName</span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="text-sm font-medium @chip.Text">@chip.Label</span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="flex items-center justify-end gap-2">
                                            @if (u.Status == chatbot.Pages.Admin.UserStatus.Pending)
                                            {
                                                <form method="post" asp-page-handler="Approve" asp-route-id="@u.Id" class="inline">
                                                    <input type="hidden" name="Search" value="@Model.Search" />
                                                    <input type="hidden" name="DepartmentId" value="@Model.DepartmentId" />
                                                    <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                                                    <button type="submit" class="px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition">Phê duyệt</button>
                                                </form>
                                                <form method="post" asp-page-handler="Reject" asp-route-id="@u.Id" class="inline">
                                                    <input type="hidden" name="Search" value="@Model.Search" />
                                                    <input type="hidden" name="DepartmentId" value="@Model.DepartmentId" />
                                                    <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                                                    <button type="submit" class="px-3 py-1.5 border border-gray-300 text-gray-600 rounded-lg text-sm font-medium hover:bg-gray-50 transition">Từ chối</button>
                                                </form>
                                            }
                                            else if (u.Status == chatbot.Pages.Admin.UserStatus.Locked)
                                            {
                                                <form method="post" asp-page-handler="Activate" asp-route-id="@u.Id" class="inline">
                                                    <input type="hidden" name="Search" value="@Model.Search" />
                                                    <input type="hidden" name="DepartmentId" value="@Model.DepartmentId" />
                                                    <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                                                    <button type="submit" class="px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white rounded-lg text-sm font-medium transition">Kích hoạt lại</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form method="post" asp-page-handler="Reject" asp-route-id="@u.Id" class="inline">
                                                    <input type="hidden" name="Search" value="@Model.Search" />
                                                    <input type="hidden" name="DepartmentId" value="@Model.DepartmentId" />
                                                    <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                                                    <button type="submit" class="px-3 py-1.5 border border-gray-300 text-gray-600 rounded-lg text-sm font-medium hover:bg-gray-50 transition" title="Khoá tài khoản">Khoá</button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <!-- Pagination -->
                    <nav aria-label="Pagination" class="flex items-center justify-between px-6 py-4 border-t border-gray-200">
                        @{
                            var pageSize = chatbot.Pages.Admin.AdminIndexModel.PageSize;
                            var startItem = (Model.PageNumber - 1) * pageSize + 1;
                            var endItem = Math.Min(Model.PageNumber * pageSize, Model.TotalCount);
                        }
                        <p class="text-sm text-gray-500">Hiển thị @startItem-@endItem trong tổng @Model.TotalCount</p>
                        <div class="flex items-center gap-1">
                            @if (Model.PageNumber <= 1)
                            {
                                <span class="px-3 py-1.5 text-sm text-gray-400 rounded-lg border border-gray-200 pointer-events-none opacity-50">Trước</span>
                            }
                            else
                            {
                                <a href="?Search=@Model.Search&DepartmentId=@Model.DepartmentId&PageNumber=@(Model.PageNumber - 1)"
                                   class="px-3 py-1.5 text-sm text-gray-600 rounded-lg border border-gray-300 hover:bg-gray-50 transition">Trước</a>
                            }

                            @{
                                var pages = new List<int>();
                                if (Model.TotalPages <= 5)
                                {
                                    for (var i = 1; i <= Model.TotalPages; i++) pages.Add(i);
                                }
                                else
                                {
                                    pages.Add(1);
                                    if (Model.PageNumber > 3) pages.Add(-1);
                                    for (var i = Math.Max(2, Model.PageNumber - 1); i <= Math.Min(Model.TotalPages - 1, Model.PageNumber + 1); i++)
                                        pages.Add(i);
                                    if (Model.PageNumber < Model.TotalPages - 2) pages.Add(-1);
                                    pages.Add(Model.TotalPages);
                                }
                            }
                            @foreach (var p in pages)
                            {
                                if (p == -1)
                                {
                                    <span class="w-8 h-8 flex items-center justify-center text-sm text-gray-400">...</span>
                                }
                                else if (p == Model.PageNumber)
                                {
                                    <span class="w-8 h-8 flex items-center justify-center rounded-lg text-sm bg-blue-600 text-white font-medium">@p</span>
                                }
                                else
                                {
                                    <a href="?Search=@Model.Search&DepartmentId=@Model.DepartmentId&PageNumber=@p"
                                       class="w-8 h-8 flex items-center justify-center rounded-lg text-sm text-gray-600 border border-gray-300 hover:bg-gray-50 transition">@p</a>
                                }
                            }

                            @if (Model.PageNumber >= Model.TotalPages)
                            {
                                <span class="px-3 py-1.5 text-sm text-gray-400 rounded-lg border border-gray-200 pointer-events-none opacity-50">Sau</span>
                            }
                            else
                            {
                                <a href="?Search=@Model.Search&DepartmentId=@Model.DepartmentId&PageNumber=@(Model.PageNumber + 1)"
                                   class="px-3 py-1.5 text-sm text-gray-600 rounded-lg border border-gray-300 hover:bg-gray-50 transition">Sau</a>
                            }
                        </div>
                    </nav>
                </div>
            </main>

            <!-- Footer -->
            <footer class="bg-white border-t border-gray-200 py-3 px-6 text-center shrink-0">
                <p class="text-xs text-gray-400">&copy; 2026 Trung tâm ĐMST &amp; CĐS Lâm Đồng III. Hệ thống quản trị AI hợp nhất.</p>
            </footer>
        </div>
    </div>
</body>
</html>
