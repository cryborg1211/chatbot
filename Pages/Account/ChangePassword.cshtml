@page
@model chatbot.Pages.Account.ChangePasswordModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đổi mật khẩu - LD3 AI Chatbot</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        // Match the app shell: class-based dark mode applied before first paint.
        tailwind.config = { darkMode: 'class' };
        if (localStorage.getItem('ld3-theme') === 'dark') {
            document.documentElement.classList.add('dark');
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body class="bg-gray-100 text-gray-800 antialiased min-h-screen flex flex-col dark:bg-gray-900 dark:text-gray-100">

    <!-- ==================== TOP BAR ==================== -->
    <header class="bg-white border-b border-gray-200 px-6 shrink-0 dark:bg-gray-800 dark:border-gray-700">
        <div class="h-14 flex items-center justify-between">
            <a href="/Chat" class="flex items-center gap-2.5">
                <div class="w-8 h-8 rounded-full bg-blue-50 flex items-center justify-center dark:bg-blue-900/40">
                    <i class="fa-solid fa-heart-pulse text-blue-500"></i>
                </div>
                <span class="text-base font-bold text-blue-600 dark:text-blue-400">LD3 AI Chatbot</span>
            </a>
            <a href="/Chat" class="text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 transition flex items-center gap-1.5">
                <i class="fa-solid fa-arrow-left text-xs"></i>
                <span>Quay lại</span>
            </a>
        </div>
    </header>

    <!-- ==================== MAIN CONTENT ==================== -->
    <main class="flex-1 flex flex-col items-center justify-center px-4 py-8">

        <div class="w-full max-w-md bg-white rounded-xl shadow-sm border border-gray-100 px-8 pt-8 pb-7 dark:bg-gray-800 dark:border-gray-700">

            <!-- Icon + Title -->
            <div class="flex flex-col items-center text-center mb-6">
                <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center mb-3 dark:bg-blue-900/40">
                    <i class="fa-solid fa-key text-blue-500 text-lg"></i>
                </div>
                <h1 class="text-xl font-bold text-gray-800 dark:text-gray-100">Đổi mật khẩu</h1>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1.5">
                    Nhập mật khẩu hiện tại và mật khẩu mới của bạn
                </p>
            </div>

            @if (Model.Succeeded)
            {
                <div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700 flex items-center gap-2 dark:bg-green-900/20 dark:border-green-800 dark:text-green-300">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>Đổi mật khẩu thành công.</span>
                </div>
            }

            <!-- Form -->
            <form method="post" class="space-y-4">
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
                {
                    <div asp-validation-summary="ModelOnly"
                         class="p-3 bg-red-50 border border-red-200 rounded-lg text-xs text-red-700 dark:bg-red-900/20 dark:border-red-800 dark:text-red-300"></div>
                }

                <!-- Current Password -->
                <div>
                    <label asp-for="Input.CurrentPassword" class="block text-sm font-semibold text-gray-700 mb-1.5 dark:text-gray-200">Mật khẩu hiện tại</label>
                    <div class="relative">
                        <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400">
                            <i class="fa-solid fa-lock text-sm"></i>
                        </span>
                        <input asp-for="Input.CurrentPassword" type="password" placeholder="••••••••" autocomplete="current-password"
                               class="w-full h-11 pl-10 pr-10 border border-gray-300 rounded-lg text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400 transition dark:bg-gray-900 dark:border-gray-600 dark:text-gray-100" />
                        <button type="button"
                                class="absolute right-3.5 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition"
                                onclick="const i=this.parentElement.querySelector('input');const ic=this.querySelector('i');if(i.type==='password'){i.type='text';ic.classList.replace('fa-eye','fa-eye-slash')}else{i.type='password';ic.classList.replace('fa-eye-slash','fa-eye')}">
                            <i class="fa-regular fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.CurrentPassword" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <!-- New Password -->
                <div>
                    <label asp-for="Input.NewPassword" class="block text-sm font-semibold text-gray-700 mb-1.5 dark:text-gray-200">Mật khẩu mới</label>
                    <div class="relative">
                        <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400">
                            <i class="fa-solid fa-shield-halved text-sm"></i>
                        </span>
                        <input asp-for="Input.NewPassword" type="password" placeholder="••••••••" autocomplete="new-password"
                               class="w-full h-11 pl-10 pr-10 border border-gray-300 rounded-lg text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400 transition dark:bg-gray-900 dark:border-gray-600 dark:text-gray-100" />
                        <button type="button"
                                class="absolute right-3.5 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition"
                                onclick="const i=this.parentElement.querySelector('input');const ic=this.querySelector('i');if(i.type==='password'){i.type='text';ic.classList.replace('fa-eye','fa-eye-slash')}else{i.type='password';ic.classList.replace('fa-eye-slash','fa-eye')}">
                            <i class="fa-regular fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.NewPassword" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <!-- Confirm New Password -->
                <div>
                    <label asp-for="Input.ConfirmPassword" class="block text-sm font-semibold text-gray-700 mb-1.5 dark:text-gray-200">Nhập lại mật khẩu mới</label>
                    <div class="relative">
                        <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400">
                            <i class="fa-solid fa-shield-halved text-sm"></i>
                        </span>
                        <input asp-for="Input.ConfirmPassword" type="password" placeholder="••••••••" autocomplete="new-password"
                               class="w-full h-11 pl-10 pr-10 border border-gray-300 rounded-lg text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400 transition dark:bg-gray-900 dark:border-gray-600 dark:text-gray-100" />
                        <button type="button"
                                class="absolute right-3.5 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition"
                                onclick="const i=this.parentElement.querySelector('input');const ic=this.querySelector('i');if(i.type==='password'){i.type='text';ic.classList.replace('fa-eye','fa-eye-slash')}else{i.type='password';ic.classList.replace('fa-eye-slash','fa-eye')}">
                            <i class="fa-regular fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <!-- Submit -->
                <div class="pt-2">
                    <button type="submit"
                            class="w-full h-11 bg-blue-500 hover:bg-blue-600 active:bg-blue-700 text-white font-semibold rounded-lg shadow-sm hover:shadow transition">
                        Cập nhật mật khẩu
                    </button>
                </div>
            </form>
        </div>
    </main>

</body>
</html>
