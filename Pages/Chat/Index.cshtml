@page
@model chatbot.Pages.Chat.IndexModel
@using chatbot.Models
@using chatbot.Pages.Chat
@{
    Layout = null;
    var currentId  = Model.CurrentConversation?.Id;
    var hasHistory = Model.Messages.Count > 0;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LD3 AI Chatbot - Trò chuyện</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body class="bg-white text-gray-800 antialiased h-screen flex flex-col overflow-hidden">

    <!-- ==================== TOP BAR ==================== -->
    <header class="h-14 bg-white border-b border-gray-200 flex items-center justify-between px-5 shrink-0">
        <a href="/" class="flex items-center gap-2.5">
            <div class="w-8 h-8 rounded-full bg-blue-50 flex items-center justify-center">
                <i class="fa-solid fa-heart-pulse text-blue-500"></i>
            </div>
            <span class="text-base font-bold text-blue-600">LD3 AI Chatbot</span>
        </a>
        <div class="flex items-center gap-3">
            <span class="text-sm text-gray-600 hidden sm:inline">@Model.FullName</span>
            @if (Model.IsAdmin)
            {
                <a href="/admin"
                   class="flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition shadow-sm">
                    <i class="fa-solid fa-shield-halved text-xs"></i>
                    Trang quản trị
                </a>
            }
            else
            {
                <a href="/Admin/Documents"
                   class="flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition shadow-sm">
                    <i class="fa-regular fa-file-lines text-xs"></i>
                    Quản lý tài liệu
                </a>
            }
            <div class="w-9 h-9 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center ring-2 ring-blue-100 cursor-pointer">
                <i class="fa-solid fa-user text-white text-xs"></i>
            </div>
        </div>
    </header>

    <!-- ==================== MAIN LAYOUT ==================== -->
    <div class="flex flex-1 overflow-hidden">

        <!-- Left Sidebar -->
        <aside class="w-60 bg-white border-r border-gray-200 flex flex-col shrink-0">
            <!-- New Chat Button -->
            <div class="px-4 pt-4 pb-2">
                <a href="/Chat"
                   class="flex items-center justify-center gap-2 h-10 w-full border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 active:bg-gray-100 transition">
                    <i class="fa-solid fa-plus text-xs"></i>
                    <span>Cuộc trò chuyện mới</span>
                </a>
            </div>

            <!-- Recent -->
            <div class="flex-1 overflow-y-auto px-3 pt-3">
                <p class="px-2 mb-1.5 text-[11px] font-semibold uppercase tracking-wider text-gray-400">Gần đây</p>
                <nav class="space-y-0.5">
                    @if (Model.RecentConversations.Count == 0)
                    {
                        <p class="px-3 py-2 text-xs text-gray-400 italic">Chưa có cuộc trò chuyện nào.</p>
                    }
                    @foreach (var c in Model.RecentConversations)
                    {
                        var isActive = c.Id == currentId;
                        var linkCls  = isActive
                            ? "flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium bg-blue-50 text-blue-700"
                            : "flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition";
                        var iconCls  = isActive ? "fa-regular fa-comment text-blue-500 text-xs" : "fa-regular fa-comment text-gray-400 text-xs";
                        <a href="/Chat?id=@c.Id" class="@linkCls" title="@c.Title">
                            <i class="@iconCls"></i>
                            <span class="truncate">@c.Title</span>
                        </a>
                    }
                </nav>
            </div>

            <!-- Bottom -->
            <div class="border-t border-gray-200 px-3 py-3 space-y-0.5">
                <a href="#" class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">
                    <i class="fa-solid fa-gear text-gray-400 text-sm w-5 text-center"></i>
                    <span>Cài đặt</span>
                </a>
                <form method="post" action="/Account/Logout">
                    <button type="submit"
                            class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-red-500 hover:bg-red-50 transition w-full">
                        <i class="fa-solid fa-right-from-bracket text-red-400 text-sm w-5 text-center"></i>
                        <span>Đăng xuất</span>
                    </button>
                </form>
            </div>
        </aside>

        <!-- Chat Area -->
        <div class="flex-1 flex flex-col min-w-0 bg-gray-50">

            <!-- Chat Messages Area (scrollable) -->
            <div id="messages-scroller" class="flex-1 overflow-y-auto">
                <div class="max-w-3xl mx-auto px-6 py-12">

                    <!-- Welcome (shown when no current conversation) -->
                    <div id="welcome" class="@(hasHistory ? "hidden" : "")">
                        <div class="text-center mb-10">
                            <div class="mx-auto w-16 h-16 rounded-2xl bg-blue-50 flex items-center justify-center mb-5">
                                <i class="fa-solid fa-sparkles text-blue-500 text-2xl"></i>
                            </div>
                            <h1 class="text-2xl font-bold text-gray-800 mb-2">Trung tâm Chuyển đổi số Lâm Đồng</h1>
                            <p class="text-sm text-gray-500 leading-relaxed max-w-lg mx-auto">
                                Hệ thống hỗ trợ trí tuệ nhân tạo tích hợp dữ liệu nội bộ LD3.<br />
                                Bắt đầu bằng cách nhập câu hỏi hoặc chọn gợi ý bên dưới.
                            </p>
                        </div>

                        <!-- Suggestion Chips -->
                        <div class="flex flex-wrap justify-center gap-3 mb-10">
                            <button type="button" data-suggestion="Quy trình xin cấp phép đầu tư tại Lâm Đồng?"
                                    class="flex items-center gap-2 px-4 py-2.5 bg-white border border-gray-200 rounded-full text-sm text-gray-600 hover:border-blue-300 hover:bg-blue-50/50 transition shadow-sm">
                                <i class="fa-solid fa-sparkles text-blue-400 text-xs"></i>
                                Quy trình xin cấp phép đầu tư tại Lâm Đồng?
                            </button>
                            <button type="button" data-suggestion="Hướng dẫn cài đặt chữ ký số nội bộ"
                                    class="flex items-center gap-2 px-4 py-2.5 bg-white border border-gray-200 rounded-full text-sm text-gray-600 hover:border-blue-300 hover:bg-blue-50/50 transition shadow-sm">
                                <i class="fa-solid fa-sparkles text-blue-400 text-xs"></i>
                                Hướng dẫn cài đặt chữ ký số nội bộ
                            </button>
                            <button type="button" data-suggestion="Thống kê chuyển đổi số quý 3/2023"
                                    class="flex items-center gap-2 px-4 py-2.5 bg-white border border-gray-200 rounded-full text-sm text-gray-600 hover:border-blue-300 hover:bg-blue-50/50 transition shadow-sm">
                                <i class="fa-solid fa-sparkles text-blue-400 text-xs"></i>
                                Thống kê chuyển đổi số quý 3/2023
                            </button>
                            <button type="button" data-suggestion="Chính sách hỗ trợ doanh nghiệp công nghệ"
                                    class="flex items-center gap-2 px-4 py-2.5 bg-white border border-gray-200 rounded-full text-sm text-gray-600 hover:border-blue-300 hover:bg-blue-50/50 transition shadow-sm">
                                <i class="fa-solid fa-sparkles text-blue-400 text-xs"></i>
                                Chính sách hỗ trợ doanh nghiệp công nghệ
                            </button>
                        </div>

                        <!-- Default AI greeting (only visible on the welcome screen) -->
                        <div class="flex gap-3">
                            <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center shrink-0 mt-1">
                                <i class="fa-solid fa-robot text-blue-600 text-xs"></i>
                            </div>
                            <div class="flex-1">
                                <div class="bg-white border border-gray-200 rounded-xl rounded-tl-sm p-4 shadow-sm">
                                    <p class="text-sm text-gray-700 leading-relaxed">
                                        Xin chào! Tôi là trợ lý ảo của Trung tâm Chuyển đổi số Lâm Đồng (LD3). Tôi có thể giúp gì cho bạn về quy trình nghiệp vụ hoặc tài liệu nội bộ hôm nay?
                                    </p>
                                </div>
                                <p class="text-xs text-gray-400 mt-2 flex items-center gap-1">
                                    <i class="fa-regular fa-clock"></i> @DateTime.Now.ToString("HH:mm")
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Messages container — server-rendered history + JS appends new bubbles -->
                    <div id="messages" class="space-y-6">
                        @foreach (var msg in Model.Messages)
                        {
                            if (msg.Role == ChatRole.User)
                            {
                                <div class="flex gap-3 justify-end">
                                    <div class="flex-1 max-w-[80%]">
                                        <div class="bg-blue-500 text-white rounded-xl rounded-tr-sm p-4 shadow-sm">
                                            <p class="text-sm leading-relaxed whitespace-pre-wrap">@msg.Content</p>
                                        </div>
                                        <p class="text-xs text-gray-400 mt-2 flex items-center gap-1 justify-end">
                                            <i class="fa-regular fa-clock"></i> @msg.CreatedAt.ToLocalTime().ToString("HH:mm")
                                        </p>
                                    </div>
                                    <div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center shrink-0 mt-1">
                                        <i class="fa-solid fa-user text-gray-500 text-xs"></i>
                                    </div>
                                </div>
                            }
                            else
                            {
                                var cites = IndexModel.ParseSourceCites(msg.SourceDocumentIdsJson);
                                Model.MyFeedback.TryGetValue(msg.Id, out var existingRating);
                                var upActive   = existingRating == FeedbackRating.ThumbsUp;
                                var downActive = existingRating == FeedbackRating.ThumbsDown;
                                <div class="flex gap-3">
                                    <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center shrink-0 mt-1">
                                        <i class="fa-solid fa-robot text-blue-600 text-xs"></i>
                                    </div>
                                    <div class="flex-1">
                                        <div class="bg-white border border-gray-200 rounded-xl rounded-tl-sm p-4 shadow-sm">
                                            @if (cites.Count > 0)
                                            {
                                                <div class="flex flex-wrap gap-1.5 mb-3">
                                                    @foreach (var cite in cites)
                                                    {
                                                        <span class="text-xs bg-blue-50 text-blue-700 px-2 py-1 rounded-full inline-flex items-center gap-1 max-w-[14rem]">
                                                            <i class="fa-regular fa-file-lines text-[10px]"></i>
                                                            <span class="truncate">@cite.Title</span>
                                                        </span>
                                                    }
                                                </div>
                                            }
                                            <p class="text-sm text-gray-700 leading-relaxed whitespace-pre-wrap">@msg.Content</p>
                                        </div>
                                        <div class="mt-2 flex items-center justify-between gap-2">
                                            <p class="text-xs text-gray-400 flex items-center gap-1">
                                                <i class="fa-regular fa-clock"></i> @msg.CreatedAt.ToLocalTime().ToString("HH:mm")
                                            </p>
                                            <div class="flex items-center gap-1" data-feedback-group="@msg.Id">
                                                <button type="button"
                                                        data-thumb data-message-id="@msg.Id" data-rating="1"
                                                        title="Hài lòng"
                                                        class="w-7 h-7 flex items-center justify-center rounded-md hover:bg-gray-100 transition @(upActive ? "text-blue-600 bg-blue-50" : "text-gray-400")">
                                                    <i class="fa-regular fa-thumbs-up text-xs"></i>
                                                </button>
                                                <button type="button"
                                                        data-thumb data-message-id="@msg.Id" data-rating="-1"
                                                        title="Không hài lòng"
                                                        class="w-7 h-7 flex items-center justify-center rounded-md hover:bg-gray-100 transition @(downActive ? "text-red-500 bg-red-50" : "text-gray-400")">
                                                    <i class="fa-regular fa-thumbs-down text-xs"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- Chat Input Bar -->
            <div class="border-t border-gray-200 bg-white px-6 py-3">
                <div class="max-w-3xl mx-auto">
                    <form id="chat-form" data-conversation-id="@(currentId?.ToString() ?? "")">
                        <div class="flex items-center gap-3 bg-gray-50 border border-gray-200 rounded-xl px-4 py-2.5 focus-within:ring-2 focus-within:ring-blue-500/30 focus-within:border-blue-400 transition">
                            <button type="button" class="text-gray-400 hover:text-gray-600 transition shrink-0">
                                <i class="fa-solid fa-paperclip"></i>
                            </button>
                            <input id="chat-input" name="content" type="text" autocomplete="off"
                                   placeholder="Nhập câu hỏi của bạn tại đây..."
                                   class="flex-1 bg-transparent text-sm placeholder-gray-400 focus:outline-none" />
                            <button type="button" class="text-gray-400 hover:text-gray-600 transition shrink-0">
                                <i class="fa-solid fa-microphone"></i>
                            </button>
                            <button id="chat-send" type="submit"
                                    class="flex items-center gap-1.5 text-gray-400 hover:text-blue-600 transition shrink-0">
                                <i class="fa-regular fa-paper-plane"></i>
                                <span class="text-sm font-medium">Gửi</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Footer Disclaimer -->
            <div class="bg-white border-t border-gray-100 px-6 py-2">
                <div class="max-w-3xl mx-auto flex items-center justify-between">
                    <p class="text-xs text-gray-400">
                        <i class="fa-solid fa-sparkles text-blue-300 mr-1"></i>
                        AI có thể đưa ra câu trả lời chưa chính xác. Vui lòng kiểm tra lại tài liệu gốc.
                    </p>
                    <button type="button" onclick="window.location.href='/Chat'"
                            class="flex items-center gap-1.5 text-xs text-gray-400 hover:text-blue-500 transition">
                        <i class="fa-solid fa-rotate-right"></i>
                        Làm mới hội thoại
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Copyright Footer -->
    <footer class="bg-white border-t border-gray-200 py-2 text-center shrink-0">
        <p class="text-xs text-gray-400">&copy; 2026 LD3 AI Chatbot</p>
    </footer>

    <script src="~/js/chat.js" asp-append-version="true"></script>
</body>
</html>
