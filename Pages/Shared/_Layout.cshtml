@{
    var activeNav = ViewData["ActiveNav"]?.ToString() ?? "Users";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Trang chủ") - LD3 AI Chatbot</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <partial name="_DarkModeHead" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-gray-50 text-gray-800 antialiased dark:bg-gray-900 dark:text-gray-100">
    <div class="flex h-screen overflow-hidden">

        <!-- ==================== LEFT SIDEBAR ==================== -->
        <aside class="w-64 bg-white border-r border-gray-200 flex flex-col shrink-0 dark:bg-gray-800 dark:border-gray-700">

            <!-- Logo -->
            <a href="/Chat" class="h-16 flex items-center gap-2.5 px-5 border-b border-gray-100 dark:border-gray-700">
                <img src="~/logo/IDT.webp" alt="LD3 AI Chatbot" class="h-10 w-auto object-contain" />
            </a>

            <!-- New Chat Button -->
            <div class="px-4 pt-4 pb-2">
                <a href="/Chat"
                   class="flex items-center justify-center gap-2 h-10 w-full border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 active:bg-gray-100 transition cursor-pointer dark:border-gray-600 dark:text-gray-200 dark:hover:bg-gray-700/50">
                    <i class="fa-solid fa-plus text-xs"></i>
                    <span>Cuộc trò chuyện mới</span>
                </a>
            </div>

            <!-- Scrollable Middle -->
            <div class="flex-1 overflow-y-auto px-3 pt-2">

                <!-- Admin Navigation -->
                <nav class="space-y-0.5">
                    <a href="/admin"
                       class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm @(activeNav == "Users" ? "font-medium bg-blue-50 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300" : "text-gray-600 hover:bg-gray-100 transition dark:text-gray-300 dark:hover:bg-gray-700/50")">
                        <i class="fa-solid fa-users text-sm w-5 text-center @(activeNav == "Users" ? "text-blue-500" : "text-gray-400")"></i>
                        <span>Quản lý người dùng</span>
                    </a>
                    <a href="/admin/feedback"
                       class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm @(activeNav == "Feedback" ? "font-medium bg-blue-50 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300" : "text-gray-600 hover:bg-gray-100 transition dark:text-gray-300 dark:hover:bg-gray-700/50")">
                        <i class="fa-regular fa-comment-dots text-sm w-5 text-center @(activeNav == "Feedback" ? "text-blue-500" : "text-gray-400")"></i>
                        <span>Phản hồi &amp; Đánh giá</span>
                    </a>
                    <a href="/admin/logs"
                       class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm @(activeNav == "Logs" ? "font-medium bg-blue-50 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300" : "text-gray-600 hover:bg-gray-100 transition dark:text-gray-300 dark:hover:bg-gray-700/50")">
                        <i class="fa-solid fa-clock-rotate-left text-sm w-5 text-center @(activeNav == "Logs" ? "text-blue-500" : "text-gray-400")"></i>
                        <span>Nhật ký hệ thống</span>
                    </a>
                </nav>
            </div>

        </aside>

        <!-- ==================== RIGHT AREA ==================== -->
        <div class="flex-1 flex flex-col min-w-0">

            <!-- Top Header -->
            <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-6 shrink-0 dark:bg-gray-800 dark:border-gray-700">
                <div></div>

                <!-- Right: Notification + Profile -->
                <div class="flex items-center gap-4">
                    <span class="relative w-9 h-9 flex items-center justify-center text-gray-400 cursor-not-allowed opacity-50" title="Chưa khả dụng">
                        <i class="fa-regular fa-bell text-lg"></i>
                    </span>
                    <div class="h-6 w-px bg-gray-200 dark:bg-gray-700"></div>

                    <!-- Profile dropdown (shared partial) -->
                    <partial name="_NavbarPartial" />
                </div>
            </header>

            <!-- Page Content -->
            <main class="flex-1 overflow-y-auto p-6">
                @RenderBody()
            </main>

            <!-- Footer -->
            <footer class="bg-white border-t border-gray-200 py-3 px-6 text-center shrink-0 dark:bg-gray-800 dark:border-gray-700">
                <p class="text-xs text-gray-400">&copy; 2026 Trung tâm ĐMST &amp; CĐS Lâm Đồng III. Hệ thống quản trị AI hợp nhất.</p>
            </footer>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
