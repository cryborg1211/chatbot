@using chatbot.Infrastructure.Authorization
@using chatbot.Infrastructure.Identity
@*
    Shared profile dropdown (trigger + menu + behaviour script).
    Drop into any page's top header via:  <partial name="_NavbarPartial" />
    Reads display name / role / avatar from the auth-cookie claims, so it
    needs no per-page view data. Rendered exactly once per page.
*@
@{
    var displayName = User?.FindFirst(AppClaimTypes.FullName)?.Value
                      ?? User?.Identity?.Name
                      ?? "Người dùng";
    var isAdmin     = User?.IsInRole(Roles.Admin) ?? false;
    var roleLabel   = isAdmin ? "Admin" : "Cán bộ CNTT";
    var avatarPath  = User?.FindFirst(AppClaimTypes.AvatarPath)?.Value;
}
<div class="relative" id="profileMenuWrapper">
    <!-- Trigger -->
    <button type="button" id="profileMenuButton"
            class="flex items-center gap-3 cursor-pointer hover:opacity-80 transition focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-300 rounded-lg"
            aria-haspopup="true" aria-expanded="false" aria-controls="profileMenu">
        <div class="text-right leading-tight hidden sm:block">
            <p class="text-sm font-medium text-gray-700 dark:text-gray-100">@displayName</p>
            <p class="text-xs text-gray-400">@roleLabel</p>
        </div>
        <div class="w-9 h-9 rounded-full overflow-hidden bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center ring-2 ring-blue-100 dark:ring-blue-900">
            @if (!string.IsNullOrEmpty(avatarPath))
            {
                <img src="@avatarPath" alt="Ảnh đại diện" class="w-full h-full object-cover" />
            }
            else
            {
                <i class="fa-solid fa-user text-white text-xs"></i>
            }
        </div>
        <i id="profileMenuChevron" class="fa-solid fa-chevron-down text-xs text-gray-400 transition-transform duration-200"></i>
    </button>

    <!-- Menu panel -->
    <div id="profileMenu" role="menu" aria-labelledby="profileMenuButton"
         class="hidden absolute right-0 mt-2 w-64 origin-top-right bg-white dark:bg-gray-800 rounded-xl shadow-lg ring-1 ring-black/5 dark:ring-white/10 py-2 z-50">

        <!-- Header: name + role badge -->
        <div class="px-4 py-3 border-b border-gray-100 dark:border-gray-700">
            <p class="text-sm font-semibold text-gray-800 dark:text-gray-100 truncate">@displayName</p>
            <span class="inline-flex items-center gap-1 mt-1.5 px-2 py-0.5 rounded-full text-xs font-medium @(isAdmin ? "bg-amber-50 text-amber-600 dark:bg-amber-900/30 dark:text-amber-300" : "bg-blue-50 text-blue-600 dark:bg-blue-900/40 dark:text-blue-300")">
                <i class="fa-solid @(isAdmin ? "fa-shield-halved" : "fa-id-badge") text-[10px]"></i>
                @roleLabel
            </span>
        </div>

        <!-- Items -->
        <div class="py-1">
            <a href="/Account/Avatar" role="menuitem"
               class="flex items-center gap-3 px-4 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition">
                <i class="fa-solid fa-image w-5 text-center text-gray-400"></i>
                <span>Đổi ảnh đại diện</span>
            </a>
            <a href="/Account/ChangePassword" role="menuitem"
               class="flex items-center gap-3 px-4 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition">
                <i class="fa-solid fa-key w-5 text-center text-gray-400"></i>
                <span>Đổi mật khẩu</span>
            </a>

            <!-- Theme toggle switch -->
            <button type="button" id="themeToggle" role="menuitemcheckbox"
                    class="w-full flex items-center justify-between gap-3 px-4 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition">
                <span class="flex items-center gap-3">
                    <i class="fa-solid fa-circle-half-stroke w-5 text-center text-gray-400"></i>
                    <span>Chế độ Tối/Sáng</span>
                </span>
                <span class="relative inline-flex h-5 w-9 shrink-0 items-center rounded-full bg-gray-200 dark:bg-blue-600 transition-colors">
                    <span class="inline-block h-4 w-4 transform rounded-full bg-white shadow translate-x-0.5 dark:translate-x-[18px] transition-transform"></span>
                </span>
            </button>
        </div>

        <!-- Divider -->
        <div class="border-t border-gray-100 dark:border-gray-700 my-1"></div>

        <!-- Logout (danger) -->
        <form method="post" action="/Account/Logout">
            <button type="submit" role="menuitem"
                    class="w-full flex items-center gap-3 px-4 py-2 text-sm text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-900/20 transition">
                <i class="fa-solid fa-right-from-bracket w-5 text-center"></i>
                <span>Đăng xuất</span>
            </button>
        </form>
    </div>
</div>

<script>
    // Profile dropdown: toggle, outside-click + Escape to close, theme switch.
    (function () {
        const btn = document.getElementById('profileMenuButton');
        const menu = document.getElementById('profileMenu');
        const chevron = document.getElementById('profileMenuChevron');
        const themeToggle = document.getElementById('themeToggle');
        if (!btn || !menu) return;

        function closeMenu() {
            menu.classList.add('hidden');
            btn.setAttribute('aria-expanded', 'false');
            chevron?.classList.remove('rotate-180');
        }

        btn.addEventListener('click', function (e) {
            e.stopPropagation();
            const nowHidden = menu.classList.toggle('hidden');
            btn.setAttribute('aria-expanded', String(!nowHidden));
            chevron?.classList.toggle('rotate-180', !nowHidden);
        });

        document.addEventListener('click', function (e) {
            if (!menu.classList.contains('hidden') && !menu.contains(e.target) && !btn.contains(e.target)) {
                closeMenu();
            }
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeMenu();
        });

        // Dark/Light theme toggle — persisted in localStorage, keeps menu open.
        themeToggle?.addEventListener('click', function (e) {
            e.stopPropagation();
            const isDark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('ld3-theme', isDark ? 'dark' : 'light');
        });
    })();
</script>
